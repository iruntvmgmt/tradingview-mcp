automationConfirmedOnlyInput    = input.bool(   true,       'Confirmed Bars Only',     group = AUTOMATION_GROUP)
automationConfirmedHtfInput     = input.bool(   true,       'Confirmed HTF Values',    group = AUTOMATION_GROUP)

validationStartInput            = input.time(   timestamp('01 Jan 2020 00:00 +0000'), 'Start Date', group = VALIDATION_GROUP)
