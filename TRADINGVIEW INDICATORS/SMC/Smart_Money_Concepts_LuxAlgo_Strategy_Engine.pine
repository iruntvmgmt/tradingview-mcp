trailDistanceRiskInput          = input.float(  1.0,        'Trail Distance R',          group = TRADE_GROUP, inline = 'exit4', minval = 0.1, step = 0.1)
maxStructureAgeInput            = input.int(    100,        'Max Structure Stop Age',   group = TRADE_GROUP, minval = 1)
