atrLengthInput                  = input.int(    14,         'ATR Length',               group = TRADE_GROUP, minval = 1)
atrStopMultInput                = input.float(  1.5,        'ATR Stop Multiple',        group = TRADE_GROUP, minval = 0.1, step = 0.1)
rewardRiskInput                 = input.float(  5.0,        'Reward/Risk Target',       group = TRADE_GROUP, minval = 0.25, step = 0.25, tooltip = 'The staged-exit default is designed around a 5R target, breakeven at 1R, and delayed trailing from 2R.')
riskPercentInput                = input.float(  10.0,       'Account Risk %',           group = TRADE_GROUP, minval = 0.01, maxval = 50.0, step = 0.25, tooltip = 'Maximum planned loss at the initial stop. Values above 10% are extreme and consecutive losses can rapidly destroy the account.')
brokerContractSizeInput         = input.float(  100.0,      'Broker Units Per 1.00 Lot', group = TRADE_GROUP, minval = 0.000001, step = 1.0, tooltip = 'Coinexx XAUUSD contract size from the supplied specification: 100 XAU per 1.00 lot.')
marginPerLotInput               = input.float(  831.15,     'Estimated Margin Per Lot', group = TRADE_GROUP, minval = 0.0, step = 0.01, tooltip = 'Approximate Coinexx initial margin in USD per 1.00 XAUUSD lot. Update this when the broker specification changes.')
maxMarginPercentInput           = input.float(  90.0,       'Max Margin % Of Equity',   group = TRADE_GROUP, minval = 1.0, maxval = 100.0, step = 1.0)
quantityStepInput               = input.float(  0.01,       'Broker Lot Step',          group = TRADE_GROUP, minval = 0.000001, step = 0.01)
minimumQuantityInput            = input.float(  0.01,       'Minimum Broker Lots',      group = TRADE_GROUP, minval = 0.000001, step = 0.01)
useBreakEvenInput               = input.bool(   true,       'Move Stop To Breakeven',   group = TRADE_GROUP, inline = 'exit1')
