strategy('Smart Money Concepts [LuxAlgo] Strategy Engine', 'LuxAlgo - SMC Strategy Engine', overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 500, pyramiding = 0, initial_capital = 100, commission_type = strategy.commission.cash_per_contract, commission_value = 0.01, slippage = 1, process_orders_on_close = true)
//---------------------------------------------------------------------------------------------------------------------}
//CONSTANTS & STRINGS & INPUTS
//---------------------------------------------------------------------------------------------------------------------{
