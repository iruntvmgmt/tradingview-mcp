breakEvenOffsetInput            = input.float(  0.10,       'BE Price Offset',           group = TRADE_GROUP, inline = 'exit2', minval = 0.0, step = 0.01, tooltip = 'Positive XAUUSD price offset intended to help cover commission. Spread and slippage can still produce a net loss.')
useStagedTrailInput             = input.bool(   true,       'Use Delayed Trail',         group = TRADE_GROUP, inline = 'exit3')
