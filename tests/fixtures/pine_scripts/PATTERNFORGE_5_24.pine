indicator(
     title = "PatternForge™ Pro v5.24.3 | Flags • Pennants • Wedges",
     shorttitle = "PatternForge™",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 100,
     max_bars_back = 2000)


// Optional: Add this near the top
var table titleBar = table.new(position.top_left, 1, 1, bgcolor=color.new(#1a1a1a, 90), border_width=1)
if barstate.islast
    table.cell(titleBar, 0, 0, 
         "PatternForge™ Pro", 
         text_color=color.new(#00ff88, 0), text_size=size.large, 
         bgcolor=color.new(#000000, 85))

// ========== PATTERN SELECTION ==========
patternGroup = "Pattern Selection"
detectHS = input.bool(true, "Head & Shoulders", group=patternGroup, inline="p1")
hsLastPivot = input.string("down", "", ["up", "down", "both"], group=patternGroup, inline="p1")

detectIHS = input.bool(true, "Inverse H&S", group=patternGroup, inline="p2")
ihsLastPivot = input.string("up", "", ["up", "down", "both"], group=patternGroup, inline="p2")

detectDT = input.bool(true, "Double Top", group=patternGroup, inline="p3")
dtLastPivot = input.string("down", "", ["up", "down", "both"], group=patternGroup, inline="p3")

detectDB = input.bool(true, "Double Bottom", group=patternGroup, inline="p4")
