// =========================================================================
// v9.2 INLINE HELPERS — Delta Strength & Smart Money Divergence
// =========================================================================

// Delta Strength: normalized CVD rate-of-change, −100 to +100.
// Positive = buying pressure accelerating. Negative = selling accelerating.
// Unlike flow_pressure (instantaneous ratio), this measures trajectory.
f_delta_strength(simple int len) =>
    float delta      = close > open ? volume : close < open ? -volume : 0.0
    float cvd        = ta.cum(delta)
    float cvd_change = cvd - cvd[len]
    float cvd_max    = ta.highest(math.abs(cvd - cvd[1]), len * 2)
    float strength   = cvd_max > 0 ? (cvd_change / cvd_max) * 100.0 : 0.0
    math.max(-100.0, math.min(100.0, strength))

// Smart Money Divergence: price/volume trend disagreement.
// Distribution = price rising + volume declining (exits being loaded).
// Accumulation = price falling + volume declining (quiet loading).
// v9.7.0: ATR * 0.75 price move gate added — prevents firing on NQ chop/pullbacks.
// Without this, the signal fires on every normal mean-reversion bar at these TFs.
f_smart_money_div(simple int lookback, float atr) =>
    float min_move     = atr * 0.75
    bool  price_moved  = math.abs(close - close[lookback]) >= min_move
    bool price_rising  = close > close[lookback]  and price_moved
    bool price_falling = close < close[lookback]  and price_moved
    bool vol_declining = ta.sma(volume, 5) < ta.sma(volume, 5)[lookback]
    [price_falling and vol_declining, price_rising and vol_declining]

// ── PRUNING HELPERS (v9.9.2 PATCH #24) ─────────────────────────────────────
f_prune_labels(label[] arr, int cap) =>
    while arr.size() > cap
        label.delete(arr.shift())

f_prune_lines(line[] arr, int cap) =>
    while arr.size() > cap
        line.delete(arr.shift())

f_prune_boxes(box[] arr, int cap) =>
    while arr.size() > cap
        box.delete(arr.shift())

// =========================================================================
// 🧠 DYNAMIC SCALING HELPERS — v9.5.0 
// =========================================================================
// Purpose: Timeframe-aware scaling so the indicator behaves consistently 
//          across 1m, 5m, 15m, 1h, 4h, etc.
//
// NOTE: We use `switch` instead of chained ternary (`? :`) because 
//       Pine Script v6 is very strict with multi-line ternary operators 
//       and often throws "end of line without line continuation" errors.
//       The `switch` version is cleaner and more stable.

f_tf_factor() =>
    // timeframe.in_seconds() returns the current chart timeframe in seconds.
    // We convert it to minutes for easier readability in the conditions.
    int seconds = timeframe.in_seconds()
    int m       = seconds / 60

    switch
        m <= 1  => 0.4   // 1 minute and below
        m <= 5  => 1.0   // 5 minute (our base/reference timeframe)
        m <= 15 => 1.6   // 15 minute
        m <= 60 => 3.0   // 1 hour
        => 8.0           // 4 hour and higher timeframes

// f_session_factor: scales with how many bars have elapsed this session.
//   500 bars = 1.0 (neutral). Short sessions → <1.0. Long → >1.0.
//   Clamped to [0.5, 2.5] to prevent extreme scaling on very short/long sessions.
f_session_factor(int bar_count) =>
    math.max(0.5, math.min(2.5, bar_count / 500.0))

// =========================================================================
// 🧠 EFFECTIVE DYNAMIC VALUES — v9.5.0
// Replaces raw inputs at all call sites below.
// =========================================================================
// These "eff_" variables replace the raw inputs with timeframe-aware scaling.
// Place this block EARLY — before any MA calculations or function calls 
// that use eff_fast_len, eff_granularity, etc.

float current_atr       = ta.atr(14)
float avg_atr           = ta.sma(current_atr, 50)
float volatility_factor = avg_atr > 0 ? current_atr / avg_atr : 1.0

// [2] MA effective lengths — standalone MA v2.7 style base-timeframe scaling.
simple float _ma_base_secs = float(timeframe.in_seconds(ma_base_tf))
simple float _ma_curr_secs = float(math.max(1, timeframe.in_seconds()))
simple float _tf_f_ma = ma_auto_lengths ? math.max(0.05, math.min(20.0, _ma_base_secs / _ma_curr_secs)) : 1.0
simple int eff_fast_len   = ma_auto_lengths ? math.min(500,  math.max(2, math.round(ma_fast_length   * _tf_f_ma))) : ma_fast_length
simple int eff_medium_len = ma_auto_lengths ? math.min(1000, math.max(4, math.round(ma_medium_length * _tf_f_ma))) : ma_medium_length
simple int eff_slow_len   = ma_auto_lengths ? math.min(2000, math.max(8, math.round(ma_slow_length   * _tf_f_ma))) : ma_slow_length
simple float _ma_vol_sens = ma_vol_sensitivity * 0.01
simple int ma_fast_short_len = math.max(2, math.round(eff_fast_len * (1.0 - _ma_vol_sens)))
simple int ma_fast_long_len  = math.min(500, math.max(2, math.round(eff_fast_len * (1.0 + _ma_vol_sens))))
simple int ma_med_short_len  = math.max(4, math.round(eff_medium_len * (1.0 - _ma_vol_sens)))
simple int ma_med_long_len   = math.min(1000, math.max(4, math.round(eff_medium_len * (1.0 + _ma_vol_sens))))
simple int ma_slow_short_len = math.max(8, math.round(eff_slow_len * (1.0 - _ma_vol_sens)))
simple int ma_slow_long_len  = math.min(2000, math.max(8, math.round(eff_slow_len * (1.0 + _ma_vol_sens))))
float ma_atr_hi = ta.highest(current_atr, 100)
float ma_atr_lo = ta.lowest(current_atr, 100)
float ma_atr_pct = (ma_atr_hi - ma_atr_lo) > 0.0 ? (current_atr - ma_atr_lo) / (ma_atr_hi - ma_atr_lo) : 0.5
float ma_vol_factor = ma_adaptive_vol ? (1.0 + _ma_vol_sens * (1.0 - 2.0 * ma_atr_pct)) : 1.0

// [3] Delta Strength effective length — ~100-min equivalent
int eff_delta_len = delta_strength_auto ? math.max(2, math.round(float(delta_strength_len) * 5.0 / float(math.max(1, timeframe.in_seconds() / 60)))) : delta_strength_len

// [4] ZZ Min Swing Bars — ~15-min equivalent
int eff_zz_min_swing = zz_swing_bars_auto ?math.max(1, math.round(15.0 / float(math.max(1, timeframe.in_seconds() / 60)))) :zz_min_swing_bars

// [5] Granularity Factor — TF-aware bin resolution
int eff_granularity = granularity_auto ? (
    timeframe.in_seconds() / 60 <= 1  ? math.round(granularity_factor * 1.40) :
    timeframe.in_seconds() / 60 <= 5  ? granularity_factor :
    timeframe.in_seconds() / 60 <= 15 ? math.round(granularity_factor * 0.75) :
    timeframe.in_seconds() / 60 <= 60 ? math.round(granularity_factor * 0.55) :
                                        math.round(granularity_factor * 0.35)
) : granularity_factor

// [6] Compression Trigger
int eff_compression_trigger = compression_trigger_auto ? math.min(40000, math.max(5000, math.round(float(compression_trigger_size) * float(timeframe.in_seconds() / 60) / 5.0))) : math.min(compression_trigger_size, 40000)

// [7] Bubble Age — ~500-min equivalent
int eff_bubble_age = bubble_age_auto ? math.max(5, math.round(500.0 / float(math.max(1, timeframe.in_seconds() / 60)))) : bubble_max_age_bars

// [8] Bubble Volume Threshold
float eff_bubble_vol_thresh = bubble_thresh_auto ? (
    timeframe.in_seconds() / 60 <= 1  ? bubble_vol_threshold * 1.40 :
    timeframe.in_seconds() / 60 <= 5  ? bubble_vol_threshold :
    timeframe.in_seconds() / 60 <= 15 ? bubble_vol_threshold * 0.85 :
    timeframe.in_seconds() / 60 <= 60 ? bubble_vol_threshold * 0.70 :
                                        bubble_vol_threshold * 0.55
) : bubble_vol_threshold

// [D] MA Momentum lookbacks — hoisted here (v9.8.0) so they are declared
// BEFORE the f_momentum() calls in the MA rendering block below.
// Target: ~25 min (fast) and ~50 min (medium) equivalent.
// 1m→25/50  5m→5/10  15m→2/3  1h→1/1 (floor 1)
// Inline — no toggle needed, purely time-derived like eff_zz_min_swing.
int _tf_mins_early = math.max(1, timeframe.in_seconds() / 60)
int eff_fast_mom_len   = math.max(1, math.round(25.0 / _tf_mins_early))
int eff_medium_mom_len = math.max(1, math.round(50.0 / _tf_mins_early))



// =========================================================================
// -------------------------------------------------------------------------
// ELITE MA AESTHETIC — INLINED HELPERS (mirrors EliteMA_Engine exactly)
// -------------------------------------------------------------------------
// Momentum strength: normalized −100 to +100 slope relative to recent ATR.
f_momentum(float ma, int lookback) =>
    float priceChange = ma - ma[lookback]
    float avgChange   = ta.sma(math.abs(ma - ma[1]), lookback)
    float m           = avgChange != 0.0 ? (priceChange / avgChange) * 10.0 : 0.0
    math.max(-100.0, math.min(100.0, m))

// Dynamic color: 3-tier bull/bear intensity keyed to momentum magnitude.
f_dyn_color(float momentum, bool isBull) =>
    color result = if isBull
        if momentum > 50.0
            color.new(#00ff88, 0)   // strong bull — bright mint
        else if momentum > 20.0
            color.new(#00cc66, 0)   // medium bull
        else
            color.new(#009944, 0)   // weak bull — muted green
    else
        if momentum < -50.0
            color.new(#ff0055, 0)   // strong bear — hot red
        else if momentum < -20.0
            color.new(#cc0044, 0)   // medium bear
        else
            color.new(#990033, 0)   // weak bear — dark red
    result

// Library MA type adapter. VP keeps short aliases for continuity; MA_Library
// owns the actual implementations.
f_ma_type_for_lib(string ma_t) =>
    switch ma_t
        "HMA"   => "Hull MA"
        "ZLEMA" => "ZeroLag EMA"
        => ma_t

// -------------------------------------------------------------------------
// MA CALCULATIONS
// -------------------------------------------------------------------------
var string _ma_adapt_type_next = ma_type
string ma_manual_type = f_ma_type_for_lib(ma_type)
string eff_ma_type = ma_adaptive_type ? _ma_adapt_type_next : ma_manual_type

float ma_fast_base = ma_lib.calculate(eff_ma_type, close, eff_fast_len)
float ma_medium_base = ma_lib.calculate(eff_ma_type, close, eff_medium_len)
float ma_slow_base = ma_lib.calculate(eff_ma_type, close, eff_slow_len)
float ma_fast_short = ma_lib.calculate(eff_ma_type, close, ma_fast_short_len)
float ma_fast_long = ma_lib.calculate(eff_ma_type, close, ma_fast_long_len)
float ma_medium_short = ma_lib.calculate(eff_ma_type, close, ma_med_short_len)
float ma_medium_long = ma_lib.calculate(eff_ma_type, close, ma_med_long_len)
float ma_slow_short = ma_lib.calculate(eff_ma_type, close, ma_slow_short_len)
float ma_slow_long = ma_lib.calculate(eff_ma_type, close, ma_slow_long_len)
float ma_fast   = ma_adaptive_vol ? ma_fast_short * ma_atr_pct + ma_fast_long * (1.0 - ma_atr_pct) : ma_fast_base
float ma_medium = ma_adaptive_vol ? ma_medium_short * ma_atr_pct + ma_medium_long * (1.0 - ma_atr_pct) : ma_medium_base
float ma_slow   = ma_adaptive_vol ? ma_slow_short * ma_atr_pct + ma_slow_long * (1.0 - ma_atr_pct) : ma_slow_base

bool ma_bull_aligned = ma_filter_mode == "3-MA (All Aligned)" ?
     (not na(ma_fast) and not na(ma_medium) and not na(ma_slow) and
      ma_fast > ma_medium and ma_medium > ma_slow) : false

bool ma_bear_aligned = ma_filter_mode == "3-MA (All Aligned)" ?
     (not na(ma_fast) and not na(ma_medium) and not na(ma_slow) and
      ma_fast < ma_medium and ma_medium < ma_slow) : false

bool ma_2ma_bull = ma_filter_mode == "2-MA (Fast/Medium)" ?
     (not na(ma_fast) and not na(ma_medium) and ma_fast > ma_medium) : false

bool ma_2ma_bear = ma_filter_mode == "2-MA (Fast/Medium)" ?
     (not na(ma_fast) and not na(ma_medium) and ma_fast < ma_medium) : false

float ma_ribbon_top = math.max(ma_fast, math.max(ma_medium, ma_slow))
float ma_ribbon_bot = math.min(ma_fast, math.min(ma_medium, ma_slow))
float ma_compression_pct = ma_ribbon_top != 0.0 ? (ma_ribbon_top - ma_ribbon_bot) / math.abs(ma_ribbon_top) * 100.0 : 0.0
bool ma_is_compressed = ma_compression_pct < 0.12
bool ma_is_volatile = current_atr > avg_atr * 1.5
if ma_adaptive_type
    if ma_is_volatile
        _ma_adapt_type_next := "Hull MA"
    else if ma_is_compressed
        _ma_adapt_type_next := "WMA"
    else if ma_bull_aligned or ma_bear_aligned or ma_2ma_bull or ma_2ma_bear
        _ma_adapt_type_next := "EMA"
    else
        _ma_adapt_type_next := "SMA"

// -------------------------------------------------------------------------
// MA VISUAL RENDERING — Elite MA Aesthetic
// Fast/Mid: momentum-driven 3-tier dynamic color (mirrors EliteMA_Engine)
// Slow: white when rising, gray(40) when falling
// Cloud: green(90) on full 3-MA bull align, red(90) on full bear align
// -------------------------------------------------------------------------
// v9.8.0: eff_fast_mom_len / eff_medium_mom_len replace hardcoded 5 / 10.
// f_momentum(ma_fast, 5) on 1m was measuring 5-minute slope — pure noise.
// Now targets ~25 min / ~50 min equivalent across all timeframes.

// v9.9: CIE var declarations hoisted here — earliest gate site is the MA
// background block below. Pine requires vars to be declared before first use
// at any scope level, so these must appear before any `if ... cie_state` check.
var ctx_eng.ContextState cie_state = na
// IFVG flip tracking: compare array size each confirmed bar.
// spawn_ifvg() uses array.unshift() — newest IFVG is always at index 0.
var bool ifvg_flip_bull  = false
var bool ifvg_flip_bear  = false
var int  ifvg_count_prev = 0
float fast_momentum   = f_momentum(ma_fast,   eff_fast_mom_len)
float medium_momentum = f_momentum(ma_medium, eff_medium_mom_len)

color ma_fast_color   = enable_ma_system and not na(ma_fast)   ? f_dyn_color(fast_momentum,   ma_fast   > ma_fast[1])   : na
color ma_medium_color = enable_ma_system and not na(ma_medium) ? f_dyn_color(medium_momentum, ma_medium > ma_medium[1]) : na
color ma_slow_color   = enable_ma_system and not na(ma_slow)   ?
     (ma_slow > ma_slow[1] ? color.new(color.white, 0) : color.new(color.gray, 40)) : na

color cloud_color = enable_ma_system and show_ma_cloud and not na(ma_fast) and not na(ma_medium) ?
     (ma_bull_aligned ? color.new(color.green, 90) : ma_bear_aligned ? color.new(color.red, 90) : na) : na

color bg_color = na
// v9.9: gate_ma_cross() — L5≥50, L1≥45, OPEN gate, no conflict. Refactored to pass direction.
if enable_ma_system and show_trend_bg
    int ma_dir = ma_bull_aligned or (not na(ma_fast) and not na(ma_medium) and ma_fast > ma_medium) ? 1 :
                 ma_bear_aligned or (not na(ma_fast) and not na(ma_medium) and ma_fast < ma_medium) ? -1 : 0
    if na(cie_state) or cie_state.gate_ma_cross(ma_dir)
        if ma_bull_aligned
            bg_color := c_bg_strong_bull
        else if not na(ma_fast) and not na(ma_medium) and ma_fast > ma_medium
            bg_color := c_bg_weak_bull
        else if ma_bear_aligned
            bg_color := c_bg_strong_bear
        else if not na(ma_fast) and not na(ma_medium) and ma_fast < ma_medium
            bg_color := c_bg_weak_bear

plot(enable_ma_system and show_ma_visual ? ma_fast   : na, "Fast MA",   color=ma_fast_color,   linewidth=2)
plot(enable_ma_system and show_ma_visual ? ma_medium : na, "Medium MA", color=ma_medium_color, linewidth=2)
plot(enable_ma_system and show_ma_visual ? ma_slow   : na, "Slow MA",   color=ma_slow_color,   linewidth=3)

p_fast   = plot(enable_ma_system and show_ma_visual and show_ma_cloud ? ma_fast   : na, display=display.none)
p_medium = plot(enable_ma_system and show_ma_visual and show_ma_cloud ? ma_medium : na, display=display.none)
fill(p_fast, p_medium, color=cloud_color, title="MA Cloud")
bgcolor(bg_color, title="Trend Background")

// -------------------------------------------------------------------------
// PART 2: STATE VARIABLES & SESSION LOGIC
// -------------------------------------------------------------------------

// ── FVG / IFVG Types (v9.4) ───────────────────────────────────────────────
// Types now live in GodTier_FVG library. Arrays declared below using
// fvg_lib.FairValueGap and fvg_lib.InverseFVG imported types.

var ctrl.SessionState session_state = ctrl.new_session(bar_index, high, low)

var box[]      profile_boxes      = array.new<box>()
var line[]     ghost_trail_lines  = array.new<line>()
var label[]    session_labels     = array.new<label>()
var box[]      va_cloud_boxes     = array.new<box>()   // v9.6.0: adaptive tile ring buffer (restored from v9.4.7)
var box        active_va_cloud    = na                 // v9.6.0: live tile covering gap from last spawn to now
// v9.8.2: Session-length tracker for adaptive spawn_interval.
// Bootstrapped on bar 0 using sessionType + timeframe to estimate expected bars per session,
// then updated on every zoneEnd with the ACTUAL confirmed bar count.
// This means spawn_interval is correctly calibrated from session 1 (not just session 2+).
var int        prev_session_bars  = 100                // overridden on barstate.isfirst below
var box[]      imbalance_zones    = array.new<box>()
var box[]      fast_lane_boxes    = array.new<box>()   // single unified array (v9.1)
var box[]      lvn_boxes          = array.new<box>()
var line[]     level_lines        = array.new<line>()
var polyline[] vp_polylines       = array.new<polyline>()
var bubbles.BubbleData[] active_bubbles = array.new<bubbles.BubbleData>()
var label[]    pattern_labels     = array.new<label>()
// v9.4 FVG arrays — types imported from GodTier_FVG
var fvg_lib.FairValueGap[] fvg_array  = array.new<fvg_lib.FairValueGap>()
var fvg_lib.InverseFVG[]   ifvg_array = array.new<fvg_lib.InverseFVG>()

// Order Flow tracking
var float cumulative_delta   = 0.0
var float normalized_cvd     = 0.0
var float flow_pressure      = 0.0
var float vwad               = 0.0
var float session_cvd_high   = 0.0
var float session_cvd_low    = 0.0
var float prev_high          = na
var float prev_low           = na
var float prev_high_delta    = na
var float prev_low_delta     = na
var float prior_poc          = na
var int   rotation_up        = 0
var int   rotation_down      = 0
var float rotation_factor    = 0.0
var string profile_shape     = "Balanced"
var float skewness_ratio     = 1.0

// v9.2 [2]: Delta Strength
var float delta_strength     = 0.0

// v9.2 [3]: Smart Money Divergence
var bool  smd_accumulation   = false
var bool  smd_distribution   = false

// v9.2 [1]: ZZ Structural Sweep state
var float  zz_resistance     = na
var float  zz_support        = na
var int    zz_struct_bias    = 0
var bool   zz_bull_sweep     = false
var bool   zz_bear_sweep     = false
var bool   zz_bull_sweep_raw = false
var bool   zz_bear_sweep_raw = false
var bool   zz_bull_sweep_pending = false
var bool   zz_bear_sweep_pending = false
var bool   zz_high_conv_bull = false   // sweep + failed auction coincide
var bool   zz_high_conv_bear = false

// v9.3: Market Structure drawing state
var line[]  ms_zz_lines     = array.new<line>()   // zigzag connecting lines
var label[] ms_hhll_labels  = array.new<label>()  // HH/HL/LH/LL labels
var label[] ms_bos_labels   = array.new<label>()  // BOS/CHoCH labels
var line    ms_res_line     = na                   // persistent resistance level
var line    ms_sup_line     = na                   // persistent support level
var line    ms_eq_line      = na                   // persistent equilibrium

// Last confirmed swing tracking — for ZZ line endpoint
var float ms_last_swing_price = na
var int   ms_last_swing_bar   = na

// BOS/CHoCH persistent state
var bool zz_bull_bos    = false
var bool zz_bear_bos    = false
var bool zz_bull_choch  = false
var bool zz_bear_choch  = false

// Structure quality scores (0-100)
var float zz_score_long  = 0.0
var float zz_score_short = 0.0

// v9.3 SR Patch: Historical S/R level arrays
var line[]  ms_hist_res_lines  = array.new<line>()    // accumulated resistance history
var line[]  ms_hist_sup_lines  = array.new<line>()    // accumulated support history
var label[] ms_hist_res_labels = array.new<label>()   // price labels on hist resistance
var label[] ms_hist_sup_labels = array.new<label>()   // price labels on hist support

// [v9.9.5-SR]: Pivot G-Tier Visual Engine Variables
var float pvtSeriesHi = na
var float pvtSeriesLo = na
var float zzShelfHi   = na
var float zzShelfLo   = na
var int   pvtCountHi  = 0
var int   pvtCountLo  = 0
var int   zzShelfCountHi = 0
var int   zzShelfCountLo = 0
// Live S/R price labels (redrawn on barstate.islast, extended every bar)
var label   ms_res_label       = na
var label   ms_sup_label       = na
var label   ms_eq_label        = na

// v9.9.2 PATCH #26: delta_history / price_history arrays removed —
// of.detect_exhaustion() telescopes to arr[last]-arr[0] = close[4]-close[0].
// Pine series history operator replaces the rolling window entirely.
var float memory_usage               = 0.0
var bool  emergency_cleanup_triggered= false
var string compression_trigger_reason= "None"

var int   last_poc_bar    = 0
var float last_poc_price  = na
var color last_ghost_color= color.gray

// VA breathing
var float  prior_va_width       = na
var string va_state             = "Neutral"
var int    va_expansion_count   = 0
var int    va_contraction_count = 0

// v9.1: Prior session VA reference
var float prior_session_vah      = na
var float prior_session_val      = na
var float prior_session_poc      = na
var box   prior_va_ref_box       = na
var int   prior_va_close_above   = 0
var int   prior_va_close_inside  = 0
var int   prior_va_close_below   = 0
var int   prior_va_touch_vah     = 0
var int   prior_va_touch_val     = 0
var bool  prior_va_poc_tested    = false
var line  prior_vah_line         = na
var line  prior_val_line         = na
var line  prior_poc_line         = na
var label prior_va_status_label  = na

// v9.1: VA reclaim/rejection border tracking
var bool  prev_price_inside_va  = true

// Trend state
var float  hourly_poc           = na
var int    last_hour            = na
var bool   trend_confirmed      = false
var bool   trend_weak           = false
var bool   uptrend_confirmed    = false
var bool   downtrend_confirmed  = false
var bool   weak_uptrend         = false
var bool   weak_downtrend       = false
var bool   failed_auction_bull  = false
var bool   failed_auction_bear  = false
var bool   failed_auction_bull_probe = false
var bool   failed_auction_bear_probe = false
var bool   failed_auction_bull_pending = false
var bool   failed_auction_bear_pending = false
var float  fa_bull_level = na
var float  fa_bear_level = na
var int    fa_bull_bar = na
var int    fa_bear_bar = na
var float  fa_last_bull_level = na
var float  fa_last_bear_level = na
var int    fa_last_bull_bar = na
var int    fa_last_bear_bar = na

varip int  tick_counter         = 0
tick_counter += 1

// Real-time POC
var float  live_poc             = na
var float  confirmed_poc        = na

// Market state
var string current_market_state       = "INITIALIZING"
var color  current_market_state_color = color.gray
var int    market_state_changes       = 0

var label  current_session_label      = na


// -------------------------------------------------------------------------
// SESSION DETECTION
// -------------------------------------------------------------------------
utcHour      = hour(time(timeframe.period, '0000-2400', 'GMT'), 'GMT')
newTokyo     = (utcHour == 0  and utcHour[1] != 0)
newLondon    = (utcHour == 7  and utcHour[1] != 7)
newNewYork   = (utcHour == 13 and utcHour[1] != 13)
newDaily     = dayofweek  != dayofweek[1]
newWeekly    = weekofyear != weekofyear[1]
newMonthly   = month      != month[1]
newYearly    = year       != year[1]
newQuarterly = month      != month[1] and (month - 1) % 3 == 0

newSession = switch sessionType
    'Tokyo'    => newTokyo
    'London'   => newLondon
    'New York' => newNewYork
    'Daily'    => newDaily
    'Weekly'   => newWeekly
    'Monthly'  => newMonthly
    'Yearly'   => newYearly
    'Quarterly'=> newQuarterly
    =>             newDaily

zoneEnd = newSession

// =========================================================================
// v9.8.2: SESSION-AWARE BOOTSTRAP — runs once on bar 0
// =========================================================================
// Estimates expected bars per session from sessionType + timeframe.
// This seeds prev_session_bars so spawn_interval is correct from session 1,
// not just session 2+ (which is when the first actual zoneEnd fires).
//
// Session duration map (seconds):
//   New York   = 6.75h RTH  = 24,300s
//   London     = 8h          = 28,800s
//   Tokyo      = 9h          = 32,400s
//   Daily      = 24h         = 86,400s   (futures: 23h but close enough)
//   Weekly     = 7 days      = 604,800s
//   Monthly    = 30 days     = 2,592,000s
//   Quarterly  = 91 days     = 7,862,400s
//   Yearly     = 365 days    = 31,536,000s
if barstate.isfirst
    int _sess_s = sessionType == 'New York'  ? 24300 : sessionType == 'London'    ? 28800 : sessionType == 'Tokyo'     ? 32400 : sessionType == 'Daily'     ? 86400 : sessionType == 'Weekly'    ? 604800 : sessionType == 'Monthly'   ? 2592000 : sessionType == 'Quarterly' ? 7862400 : sessionType == 'Yearly'    ? 31536000 : 86400
    prev_session_bars := math.max(2, math.round(_sess_s / timeframe.in_seconds()))

// -------------------------------------------------------------------------
// CORE LOGIC LOOP
// -------------------------------------------------------------------------
bool enable_threshold_compression = compression_mode == "Threshold-Only" or compression_mode == "Hybrid"
bool enable_time_compression      = compression_mode == "Time-Only"      or compression_mode == "Hybrid"

string ltf_res = timeframe.isseconds ? "1S" : (timeframe.isintraday and timeframe.multiplier < 5) ? "1" : "5"
[do, dC, dH, dL, dV] = request.security_lower_tf(syminfo.tickerid, ltf_res,
    [open, close, high, low, volume], ignore_invalid_timeframe=true)

if na(do) or do.size() == 0
    do := array.from(open)
if na(dC) or dC.size() == 0
    dC := array.from(close)
if na(dH) or dH.size() == 0
    dH := array.from(high)
if na(dL) or dL.size() == 0
    dL := array.from(low)
if na(dV) or dV.size() == 0
    dV := array.from(volume)

// =========================================================================
// PART 4: SESSION TRANSITIONS
// =========================================================================
// AUDIT FIX 1: Session reset now runs BEFORE the per-bar volume update.
// The previous late second update included the opening bar, but left early
// session-dependent logic using stale old-session values. This ordering gives
// update_incremental(), session_bar_count, compression labeling, FVG gating,
// CIE, and rendering one coherent fresh-session state.
if zoneEnd
    // v9.8.2: Snapshot session bar count BEFORE reset so next session's spawn_interval
    // is calibrated to actual session length (NQ RTH 1h ≈ 7 bars, SOL 1h ≈ 24 bars).
    prev_session_bars := math.max(1, bar_index - session_state.start_bar)
    // Capture prior session VA before cloud/ghost wipe
    if not na(session_state.vah) and not na(session_state.val)
        prior_session_vah := session_state.vah
        prior_session_val := session_state.val
        prior_session_poc := session_state.poc

    while array.size(ghost_trail_lines) > 0
        line.delete(array.shift(ghost_trail_lines))
    // ✅ v9.6.0: Tear down full tile array (restored with tile system)
    while array.size(va_cloud_boxes) > 0
        box.delete(array.shift(va_cloud_boxes))
    if not na(active_va_cloud)
        box.delete(active_va_cloud)
        active_va_cloud := na
    bubbles.clear_bubbles(active_bubbles)
    if not na(current_session_label)
        label.delete(current_session_label)
        current_session_label := na
    // v9.4: Clear FVG/IFVG zones on session boundary
    fvg_lib.clear_session(fvg_array, ifvg_array)

if newSession
    // Cap the prior-VA reference box at this session boundary,
    // then start a fresh one from the new session start.
    if show_prior_va
        if not na(prior_va_ref_box)
            box.set_right(prior_va_ref_box, bar_index)
        if not na(prior_vah_line)
            line.set_x2(prior_vah_line, bar_index)
        if not na(prior_val_line)
            line.set_x2(prior_val_line, bar_index)
        if not na(prior_poc_line)
            line.set_x2(prior_poc_line, bar_index)

        if not na(prior_session_vah) and not na(prior_session_val)
            // Layer 1: Background zone (start neutral)
            prior_va_ref_box := box.new(
                left         = bar_index,
                top          = prior_session_vah,
                right        = bar_index + 500,
                bottom       = prior_session_val,
                border_color = color.new(c_prior_va, 80),
                border_width = 1,
                border_style = line.style_dotted,
                bgcolor      = color.new(c_prior_va, 90)
            )
            // Layer 2: VAH/VAL Lines
            prior_vah_line := line.new(bar_index, prior_session_vah, bar_index + 500, prior_session_vah,
                color=color.new(c_prior_va, 40), width=1, style=line.style_dashed)
            prior_val_line := line.new(bar_index, prior_session_val, bar_index + 500, prior_session_val,
                color=color.new(c_prior_va, 40), width=1, style=line.style_dashed)

            // Layer 3: Prior POC (Naked POC line)
            if not na(prior_session_poc)
                prior_poc_line := line.new(bar_index, prior_session_poc, bar_index + 500, prior_session_poc,
                    color=color.new(color.white, 50), width=2, style=line.style_dotted)
                prior_va_status_label := label.new(bar_index + 5, prior_session_poc, "NPOC",
                    color=color.new(color.black, 100), textcolor=color.new(color.white, 30),
                    style=label.style_label_left, size=size.tiny)

    session_state := ctrl.reset_session(session_state, bar_index)
    cumulative_delta   := of.reset_cvd()
    normalized_cvd     := 0.0
    live_poc           := na
    confirmed_poc      := na
    flow_pressure      := 0.0
    vwad               := 0.0
    session_cvd_high   := 0.0
    session_cvd_low    := 0.0
    prior_poc          := na
    rotation_up        := 0
    rotation_down      := 0
    rotation_factor    := 0.0
    compression_trigger_reason := "None"

    last_poc_price         := na
    last_poc_bar           := bar_index
    prior_va_width         := na
    // Phase 1 Resets
    prior_va_close_above  := 0
    prior_va_close_inside := 0
    prior_va_close_below  := 0
    prior_va_touch_vah    := 0
    prior_va_touch_val    := 0
    prior_va_poc_tested   := false
    // v9.9.1 PATCH #7: Corrected newSession va_state reset from "Stable" → "Neutral".
    // "Neutral" is the correct state for session open before VA is measured.
    // The rendering block maps "Neutral" to amber rgb(180,140,60) at 55% transparency
    // (more opaque, early-session visibility). "Stable" maps to blue-grey rgb(140,160,200)
    // at 75% transparency and is only correct after the first VA width comparison fires.
    // Note: The v9.6.0 comment about "silver color fix" referred to the Stable color
    // change (color.silver → rgb(140,160,200)), NOT to the state string here — that
    // partial note was misleading and is removed.
    va_state               := "Neutral"
    va_expansion_count     := 0
    va_contraction_count   := 0
    hourly_poc             := na
    trend_confirmed        := false
    trend_weak             := false
    profile_shape          := "Balanced"
    skewness_ratio         := 1.0
    // AUDIT: duplicate compression_trigger_reason reset removed (first reset above)
    emergency_cleanup_triggered   := false
    current_market_state          := "INITIALIZING"
    market_state_changes          := 0
    prev_price_inside_va          := true
    // v9.2: reset new state on session boundary
    delta_strength         := 0.0
    smd_accumulation       := false
    smd_distribution       := false
    failed_auction_bull    := false
    failed_auction_bear    := false
    failed_auction_bull_probe := false
    failed_auction_bear_probe := false
    failed_auction_bull_pending := false
    failed_auction_bear_pending := false
    fa_bull_level          := na
    fa_bear_level          := na
    fa_bull_bar            := na
    fa_bear_bar            := na
    fa_last_bull_level     := na
    fa_last_bear_level     := na
    fa_last_bull_bar       := na
    fa_last_bear_bar       := na
    zz_high_conv_bull      := false
    zz_high_conv_bear      := false
    // v9.3: reset market structure event state on session boundary
    // (persistent swing levels zz_resistance/zz_support carry over — they are
    //  structural, not session-scoped. BOS/CHoCH are event flags, reset these.)
    zz_bull_bos            := false
    zz_bear_bos            := false
    zz_bull_choch          := false
    zz_bear_choch          := false
    ms_last_swing_price    := na
    ms_last_swing_bar      := na
    // Clear session-scoped MS drawing arrays
    if array.size(ms_zz_lines) > 0
        for i = array.size(ms_zz_lines) - 1 to 0
            line.delete(array.get(ms_zz_lines, i))
    array.clear(ms_zz_lines)
    if array.size(ms_hhll_labels) > 0
        for i = array.size(ms_hhll_labels) - 1 to 0
            label.delete(array.get(ms_hhll_labels, i))
    array.clear(ms_hhll_labels)
    if array.size(ms_bos_labels) > 0
        for i = array.size(ms_bos_labels) - 1 to 0
            label.delete(array.get(ms_bos_labels, i))
    array.clear(ms_bos_labels)

if array.size(dC) > 0 and array.size(dV) > 0 and array.size(dH) > 0 and array.size(dL) > 0
    // ✅ v9.4.1 FIX: Pass LTF highs and lows to fix volume distribution corruption (Bug #1)
    // AUDIT FIX 1: Runs after any session reset, so the first bar of a
    // new session is included without contaminating the prior session.
    session_state := ctrl.update_incremental(session_state, do, dC, dH, dL, dV, va_percentage,
        enable_threshold_compression, eff_compression_trigger, compression_factor, eff_granularity)

// v9.9.1 PATCH #1: Controller-sourced compression was being labeled "Time" or
// "Threshold" via a post-compression map.size() guess. After compression fires,
// map.size() is already reduced — the ternary was unreliable and produced "Time"
// for most Controller threshold events, silently breaking the "Time-Based" alert
// condition. Label as "Controller" to distinguish from explicitly-detected paths.
if session_state.compression_applied and compression_trigger_reason == "None"
    compression_trigger_reason := "Controller"

int session_bar_count = bar_index - session_state.start_bar
if enable_time_compression and not session_state.compression_applied and session_bar_count > time_compression_bars
    if session_bar_count % 500 == 0
        session_state.vol_map  := opt.compress_profile(session_state.vol_map,  compression_factor)
        session_state.buy_map  := opt.compress_profile(session_state.buy_map,  compression_factor)
        session_state.sell_map := opt.compress_profile(session_state.sell_map, compression_factor)
        session_state.bin_size := session_state.bin_size * compression_factor
        session_state.compression_applied := true
        compression_trigger_reason := "Time-Based"

if enable_multi_stage and session_state.compression_applied and map.size(session_state.vol_map) >= math.round(eff_compression_trigger * 1.5)
    session_state.vol_map  := opt.compress_profile(session_state.vol_map,  compression_factor)
    session_state.buy_map  := opt.compress_profile(session_state.buy_map,  compression_factor)
    session_state.sell_map := opt.compress_profile(session_state.sell_map, compression_factor)
    session_state.bin_size := session_state.bin_size * compression_factor
    compression_trigger_reason := "Multi-Stage"
// =========================================================================
// 🧠 EFFECTIVE DYNAMIC VALUES — Part 2 (Session-Dependent)
// =========================================================================
// Place this block AFTER session_state is updated and session_bar_count is available.
// This avoids "undefined" errors for session_state.start_bar and volatility_factor.
// [9] Imbalance ratio — volatility-aware (NQ=orderly, BTC=chaotic)
float _atr_vol_ratio    = avg_atr > 0 ? math.max(0.7, math.min(2.0, current_atr / avg_atr)) : 1.0
float eff_imbalance_ratio = imbalance_ratio_auto ? imbalance_ratio * _atr_vol_ratio : imbalance_ratio

// [10] VA Breathing thresholds — scale with session volatility
float _va_vol_factor    = math.max(0.7, math.min(1.5, volatility_factor))
float eff_va_expansion  = va_breath_auto ? 1.0 + (va_expansion_threshold   - 1.0) * _va_vol_factor : va_expansion_threshold
float eff_va_contraction = va_breath_auto ? 1.0 - (1.0 - va_contraction_threshold) * _va_vol_factor : va_contraction_threshold

// [11] LVN & Fast Lane void thresholds — scale with session bar count
// NOTE: session_bar_count computed below at line ~789; these use the var
// updated each bar. On bar 0 it will be 0 so _sess_f = 0.5 (floor).
float _sess_f_eff        = f_session_factor(bar_index - session_state.start_bar)
float eff_lvn_threshold  = void_thresh_auto ? math.min(0.35, lvn_threshold * (1.0 / math.max(0.5, _sess_f_eff))) : lvn_threshold
float eff_fast_lane_threshold = void_thresh_auto ? math.min(0.4, fast_lane_threshold * (1.0 / math.max(0.5, _sess_f_eff))) : fast_lane_threshold

// =========================================================================
// 🧠 EFFECTIVE DYNAMIC VALUES — v9.8.0 (Remaining Auto-Scale Fixes)
// =========================================================================
// Every remaining hardcoded threshold now has a physical anchor:
// time-equivalent bars, ATR-relative price distance, or volume-relative delta.
// After these, every parameter in the system is either scaled or a dimensionless
// ratio that doesn't need scaling.

int _tf_mins = _tf_mins_early   // alias — already computed in Part 1 eff_ block above

// [A] Failed Auction lookback — target ~40 min equivalent
//     1m→40 bars  5m→8 bars  15m→3 bars  1h→2 bars (floor)
int eff_fa_lookback = fa_lookback_auto ? math.max(2, math.round(40.0 / _tf_mins)) : failed_auction_lookback

// [B] SMD lookback — target ~50 min equivalent
//     1m→50 bars  5m→10 bars  15m→3 bars  1h→2 bars (floor)
int eff_smd_lookback = smd_lookback_auto ? math.max(2, math.round(50.0 / _tf_mins)) : smd_lookback

// [C] FVG extend bars — target ~100 min forward projection
//     1m→100 bars  5m→20 bars  15m→7 bars  1h→2 bars (floor)
int eff_fvg_extend = fvg_extend_auto ? math.max(2, math.round(100.0 / _tf_mins)) : fvg_extend_bars

// [D] MA Momentum lookbacks — declared in Part 1 eff_ block (before MA calcs).
//     eff_fast_mom_len / eff_medium_mom_len already available here.

// [E] Bubble proximity — ATR × 0.12 replaces mintick × ticks
float eff_bubble_prox = current_atr * 0.12

// [F] POC drift display threshold — ATR × 0.04 replaces mintick × 5
float eff_poc_drift = current_atr * 0.04

// Current chart-bar delta from LTF components. Session totals are cumulative and
// must not be reused as per-bar delta, or CVD/delta thresholds double-integrate.
float current_bar_delta = 0.0
int _delta_n = math.min(array.size(dV), math.min(array.size(do), array.size(dC)))
if _delta_n > 0
    for _di = 0 to _delta_n - 1
        float _o = array.get(do, _di)
        float _c = array.get(dC, _di)
        float _v = array.get(dV, _di)
        current_bar_delta += _c >= _o ? _v : -_v

// [G] Bubble min delta — int cast required (BubbleConfig.min_delta is series int)
//     5% of avg bar delta. math.round() + math.max(1) prevents zero on thin sessions.
float _avg_bar_delta       = ta.sma(math.abs(current_bar_delta), 20)
int   eff_bubble_min_delta = math.max(1, math.round(_avg_bar_delta * 0.05))

// Restored: adaptive_spacing was removed during v9.8.0 block insertion
int   adaptive_spacing   = volatility_factor > 1.5 ? math.max(2, math.round(min_tick_spacing / 2)) : min_tick_spacing
float live_close         = close
float live_high          = high
float live_low           = low
float live_volume        = volume
bool  should_check_now   = barstate.isrealtime and (tick_counter % adaptive_spacing == 0)  // ← ADD THIS
bool  execute_now        = realtime_execution ? should_check_now : barstate.isconfirmed

// -------------------------------------------------------------------------
// PART 3: ORDER FLOW ANALYSIS & PATTERN DETECTION
// -------------------------------------------------------------------------

if show_delta and bar_index > 0
    cumulative_delta := session_state.cumulative_delta
    session_cvd_high := math.max(session_cvd_high, cumulative_delta)
    session_cvd_low  := math.min(session_cvd_low,  cumulative_delta)
    normalized_cvd   := of.normalize_cvd(cumulative_delta, session_cvd_high, session_cvd_low)

    if show_flow_pressure and session_state.total_volume > 0
        flow_pressure := of.calculate_flow_pressure(session_state.total_buy, session_state.total_sell)

// VWAD — warms up with POC/VA, then follows its own cheaper 10-bar throttle
var int last_vwad_calc_bar = na
bool vwad_early_session = bar_index - session_state.start_bar <= 3
if vwad_early_session or na(last_vwad_calc_bar) or (bar_index - last_vwad_calc_bar) >= 10 or barstate.islast
    if session_state.vol_map.size() > 0
        map<int, float> delta_map_vwad = map.new<int, float>()
        for [k, buy_v] in session_state.buy_map
            delta_map_vwad.put(k, buy_v - nz(session_state.sell_map.get(k)))
        vwad := of.calculate_vwad(delta_map_vwad, session_state.vol_map)
        last_vwad_calc_bar := bar_index

// ROTATION
if calc_rotation and not na(session_state.poc)
    if not na(prior_poc)
        [new_rot_up, new_rot_dn, rot_factor] = gte.updateRotation(prior_poc, session_state.poc, rotation_up, rotation_down)
        rotation_up    := new_rot_up
        rotation_down  := new_rot_dn
        rotation_factor:= rot_factor
    prior_poc := session_state.poc

// PROFILE SHAPE
if show_profile_shape and not na(session_state.poc)
    gte.ShapeAnalysis shape_result = gte.analyzeProfileShape(session_state.vol_map,
        session_state.buy_map, session_state.sell_map,
        session_state.poc, session_state.max_vol, session_state.bin_size)
    profile_shape  := shape_result.shape_type
    skewness_ratio := shape_result.skewness_ratio

// VA BREATHING METRICS
// ✅ FIX: va_state calculation runs unconditionally — show_va_metrics only gates
// the dashboard counters. The VA cloud color depends on va_state, so if this
// entire block was gated behind show_va_metrics = false, va_state stayed "Neutral"
// forever → base_col resolved to gray → cloud rendered as invisible white fill.
if not na(session_state.vah) and not na(session_state.val)
    float current_va_width = session_state.vah - session_state.val
    if not na(prior_va_width) and prior_va_width > 0
        if current_va_width > prior_va_width * eff_va_expansion
            va_state := "Expanding"
            if show_va_metrics
                va_expansion_count += 1
        else if current_va_width < prior_va_width * eff_va_contraction
            va_state := "Contracting"
            if show_va_metrics
                va_contraction_count += 1
        else
            va_state := "Stable"
    prior_va_width := current_va_width

// TREND VALIDATION
if show_trend_validation
    if hour != last_hour
        hourly_poc := session_state.poc
        last_hour  := hour

    uptrend_confirmed   := false
    downtrend_confirmed := false
    weak_uptrend        := false
    weak_downtrend      := false
    trend_confirmed     := false
    trend_weak          := false

    if not na(hourly_poc) and not na(session_state.poc)
        bool price_higher_high = high > high[1]
        bool price_lower_low   = low  < low[1]
        bool poc_higher        = session_state.poc > hourly_poc
        bool poc_lower         = session_state.poc < hourly_poc
        
        if price_higher_high and poc_higher
            trend_confirmed := true
            uptrend_confirmed := true
        else if price_lower_low and poc_lower
            trend_confirmed := true
            downtrend_confirmed := true
        else if price_higher_high and not poc_higher
            trend_weak := true
            weak_uptrend := true
        else if price_lower_low and not poc_lower
            trend_weak := true
            weak_downtrend := true

// PATTERN DETECTION
// v9.7.0: Inline 2.5× volume gate added before detectAbsorption().
// The GodTierEngine library default is 1.5× — fires constantly on NQ open/news.
// 2.5× keeps genuine high-volume absorption; filters routine event-driven bars.
// Signal still feeds dashboard and market state regardless of show_label_abs toggle.
float _abs_vol_gate = ta.sma(volume, 20) * 2.5

// v9.9.1 PATCH #12: Absorption key-level proximity gate.
// Absorption theory = smart money DEFENDING a level. Mid-VA absorption has no
// defense thesis — there is no structural level to defend there. Only absorption
// at VAH, VAL, POC, or ZZ structural levels is institutionally meaningful.
// Gate: close must be within 1.5 ATR of at least one key reference level.
// Falls back to unfiltered if VA not yet calculated (early session warmup).
float _abs_key_dist = na(session_state.vah) ? 0.0 : math.min(
    math.min(math.abs(close - session_state.vah), math.abs(close - session_state.val)),
    math.min(math.abs(close - session_state.poc),
    math.min(na(zz_resistance) ? current_atr : math.abs(close - zz_resistance),
             na(zz_support)    ? current_atr : math.abs(close - zz_support))))
bool _abs_at_key_level = na(session_state.vah) or _abs_key_dist <= current_atr * 1.5
bool absorption_signal = show_absorption ? (volume >= _abs_vol_gate and gte.detectAbsorption(volume, math.abs(close - open), current_atr) and _abs_at_key_level) : false
bool exhaustion_signal = false
string exhaustion_type = "None"

// v9.9.2 PATCH #26: Rolling arrays replaced with Pine series history operator
if show_exhaustion and bar_index > 20 and barstate.isconfirmed
    float _exh_price_net = close            - close[4]
    float _exh_delta_net = cumulative_delta - cumulative_delta[4]
    exhaustion_signal := (_exh_price_net > 0 and _exh_delta_net < 0) or
                         (_exh_price_net < 0 and _exh_delta_net > 0)
    if exhaustion_signal
        exhaustion_type := (_exh_price_net > 0 and _exh_delta_net < 0) ? "Buy Exhaustion" : "Sell Exhaustion"

bool iceberg_detected = false
if show_iceberg and bar_index > 10 and not na(session_state.bin_size)
    int current_price_bin = binning.f_get_bin_index(close, session_state.bin_size)
    
    // v9.9.1 PATCH #14: Iceberg key-level bin gate.
    // An iceberg (hidden large order at a bin) is only meaningful when it sits
    // at a contested level — VAH, VAL, POC, or ZZ levels. A 3× volume bin deep
    // inside the VA is just a historically busy price, not institutional defense.
    // Compute key bins and allow ±2 bin tolerance for ATR drift and bin granularity.
    // Falls back to unfiltered if VA not yet established (early session warmup).
    bool _iceberg_at_key = na(session_state.vah)
    if not _iceberg_at_key
        int _vah_bin = binning.f_get_bin_index(session_state.vah, session_state.bin_size)
        int _val_bin = binning.f_get_bin_index(session_state.val, session_state.bin_size)
        int _poc_bin = binning.f_get_bin_index(session_state.poc, session_state.bin_size)
        int _zz_res_bin = na(zz_resistance) ? current_price_bin + 99 : binning.f_get_bin_index(zz_resistance, session_state.bin_size)
        int _zz_sup_bin = na(zz_support)    ? current_price_bin + 99 : binning.f_get_bin_index(zz_support,    session_state.bin_size)
        int _bin_tol = 2
        _iceberg_at_key := math.abs(current_price_bin - _vah_bin)    <= _bin_tol or math.abs(current_price_bin - _val_bin)    <= _bin_tol or math.abs(current_price_bin - _poc_bin)    <= _bin_tol or math.abs(current_price_bin - _zz_res_bin) <= _bin_tol or math.abs(current_price_bin - _zz_sup_bin) <= _bin_tol
    iceberg_detected := of.detect_iceberg(session_state.vol_map, current_price_bin, 3.0) and _iceberg_at_key

bool bearish_div = false
bool bullish_div = false
if show_divergence and bar_index > 20
    [new_bear, new_bull, new_ph, new_pl, new_phd, new_pld] = gte.detectDivergence(
        high, low, cumulative_delta, prev_high, prev_low, prev_high_delta, prev_low_delta)
    // v9.9.1 PATCH #15: Divergence VA boundary filter.
    // Bearish divergence (pivot high + delta diverges) is high-conviction only when
    // the pivot forms at or above VAH — price rejected after probing above value.
    // Bullish divergence (pivot low + delta diverges) is high-conviction only when
    // the pivot forms at or below VAL — price rejected after probing below value.
    // Mid-VA divergence is price oscillating inside accepted value — expected behavior,
    // not a signal. Also accepts ZZ structural level proximity as an alternative anchor.
    // Falls back to unfiltered if VA is not yet established (early session warmup).
    bool _bear_at_boundary = na(session_state.vah) or high >= session_state.vah - current_atr * 0.5 or (not na(zz_resistance) and math.abs(high - zz_resistance) <= current_atr)
    bool _bull_at_boundary = na(session_state.val) or low  <= session_state.val + current_atr * 0.5 or (not na(zz_support) and math.abs(low - zz_support) <= current_atr)
    bearish_div := new_bear and _bear_at_boundary
    bullish_div := new_bull and _bull_at_boundary
    prev_high      := new_ph
    prev_low       := new_pl
    prev_high_delta:= new_phd
    prev_low_delta := new_pld

// FAILED AUCTION
failed_auction_bull := false
failed_auction_bear := false
failed_auction_bull_probe := false
failed_auction_bear_probe := false
if show_failed_auction and not na(session_state.vah) and not na(session_state.val) and not na(session_state.bin_size)
    float fa_atr = nz(current_atr, high - low)
    float fa_min_pen = fa_atr * fa_min_pen_atr
    float fa_disp = fa_atr * fa_displacement_atr

    bool fa_bear_cooldown_ok = na(fa_last_bear_bar) or bar_index - fa_last_bear_bar > fa_cooldown_bars or session_state.vah != fa_last_bear_level
    bool fa_bull_cooldown_ok = na(fa_last_bull_bar) or bar_index - fa_last_bull_bar > fa_cooldown_bars or session_state.val != fa_last_bull_level

    if high > ta.highest(high[1], eff_fa_lookback)
        int   bear_breakout_bin = binning.f_get_bin_index(high, session_state.bin_size)
        float bear_breakout_vol = nz(map.get(session_state.vol_map, bear_breakout_bin))
        bool bear_thin_breakout = session_state.max_vol > 0 and bear_breakout_vol < (session_state.max_vol * failed_auction_vol_threshold)
        failed_auction_bear_probe := fa_bear_cooldown_ok and bear_thin_breakout and high > session_state.vah + fa_min_pen and close < session_state.vah
        if failed_auction_bear_probe
            failed_auction_bear_pending := true
            fa_bear_level := session_state.vah
            fa_bear_bar := bar_index

    if low < ta.lowest(low[1], eff_fa_lookback)
        int   bull_breakout_bin = binning.f_get_bin_index(low, session_state.bin_size)
        float bull_breakout_vol = nz(map.get(session_state.vol_map, bull_breakout_bin))
        bool bull_thin_breakout = session_state.max_vol > 0 and bull_breakout_vol < (session_state.max_vol * failed_auction_vol_threshold)
        failed_auction_bull_probe := fa_bull_cooldown_ok and bull_thin_breakout and low < session_state.val - fa_min_pen and close > session_state.val
        if failed_auction_bull_probe
            failed_auction_bull_pending := true
            fa_bull_level := session_state.val
            fa_bull_bar := bar_index

    bool fa_bear_within = failed_auction_bear_pending and not na(fa_bear_bar) and bar_index - fa_bear_bar <= fa_confirm_bars
    bool fa_bull_within = failed_auction_bull_pending and not na(fa_bull_bar) and bar_index - fa_bull_bar <= fa_confirm_bars
    bool fa_bear_reaccepted = failed_auction_bear_pending and close > fa_bear_level
    bool fa_bull_reaccepted = failed_auction_bull_pending and close < fa_bull_level
    bool fa_bear_displaced = fa_bear_within and close < fa_bear_level - fa_disp and close < open
    bool fa_bull_displaced = fa_bull_within and close > fa_bull_level + fa_disp and close > open

    if fa_bear_displaced
        failed_auction_bear := true
        failed_auction_bear_pending := false
        fa_last_bear_level := fa_bear_level
        fa_last_bear_bar := bar_index
    else if failed_auction_bear_pending and (not fa_bear_within or fa_bear_reaccepted)
        failed_auction_bear_pending := false

    if fa_bull_displaced
        failed_auction_bull := true
        failed_auction_bull_pending := false
        fa_last_bull_level := fa_bull_level
        fa_last_bull_bar := bar_index
    else if failed_auction_bull_pending and (not fa_bull_within or fa_bull_reaccepted)
        failed_auction_bull_pending := false
else
    failed_auction_bull_pending := false
    failed_auction_bear_pending := false

// =========================================================================
// v9.2 [1]: ZZ STRUCTURAL SWEEP LAYER
// =========================================================================
// getZigZagLevels() must run every bar at top scope — var state inside.
// atrLen and minSwingBars are simple int (input values satisfy this).
// Unpack into fresh locals, then := assign to persistent var state below.
[zzRes, zzSup, zzSwingH, zzSwingL, zzBarsH, zzBarsL, zzDir, zzThresh, zzHBar, zzLBar] = zz.getZigZagLevels(false, zz_atr_len, zz_atr_mult, eff_zz_min_swing, false)
// Dedicated shelf-only ZigZag stream. Kept separate from the main structure
// engine so pvt_use_renko can affect ATR ZigZag shelves without changing CIE,
// sweeps, BOS/CHoCH, or dashboard structure state.
[zzShelfResRaw, zzShelfSupRaw, zzShelfSwingH, zzShelfSwingL, zzShelfBarsH, zzShelfBarsL, zzShelfDir, zzShelfThresh, zzShelfHBar, zzShelfLBar] = zz.getZigZagLevels(pvt_use_renko, zz_atr_len, zz_atr_mult, eff_zz_min_swing, false)

// [v9.9.5-SR]: PIVOT G-TIER Visual Engine (Mimics MA System v2.7)
// Uses a trend-adaptive EMA filter to adjust pivot sensitivity.
// Adheres to Renko Style toggle for noise filtration.
float _pvtHiSrc = pvt_use_renko ? math.max(open, close) : high
float _pvtLoSrc = pvt_use_renko ? math.min(open, close) : low

float pvtEma = ta.ema(close, 21)
int _pLenL   = pvt_use_auto ? (close > pvtEma ? pvt_left : pvt_left + 1) : pvt_left
int _pLenR   = pvt_use_auto ? (close < pvtEma ? pvt_right : pvt_right + 1) : pvt_right

float pvtHiRaw = ta.pivothigh(_pvtHiSrc, _pLenL, _pLenR)
float pvtLoRaw = ta.pivotlow(_pvtLoSrc, _pLenL, _pLenR)

// Pivot confirmation series (Standard God Tier shunt = 1)
float pvtHi = pvtHiRaw[1]
float pvtLo = pvtLoRaw[1]

pvtSeriesHi := na(pvtHi) ? pvtSeriesHi[1] : _pvtHiSrc[_pLenR + 1]
pvtSeriesLo := na(pvtLo) ? pvtSeriesLo[1] : _pvtLoSrc[_pLenR + 1]

pvtCountHi := na(pvtHi) ? nz(pvtCountHi[1]) + 1 : 0
pvtCountLo := na(pvtLo) ? nz(pvtCountLo[1]) + 1 : 0

zzShelfHi := na(zzShelfSwingH) ? zzShelfHi[1] : zzShelfSwingH
zzShelfLo := na(zzShelfSwingL) ? zzShelfLo[1] : zzShelfSwingL
zzShelfCountHi := na(zzShelfSwingH) ? nz(zzShelfCountHi[1]) + 1 : 0
zzShelfCountLo := na(zzShelfSwingL) ? nz(zzShelfCountLo[1]) + 1 : 0

// Color breaking ensures plotted historical levels do not connect through pivots.
color pvtColorHi = pvtSeriesHi != pvtSeriesHi[1] ? na : color.new(c_hist_res, 20)
color pvtColorLo = pvtSeriesLo != pvtSeriesLo[1] ? na : color.new(c_hist_sup, 20)
color zzShelfColorHi = zzShelfHi != zzShelfHi[1] ? na : color.new(c_hist_res, 20)
color zzShelfColorLo = zzShelfLo != zzShelfLo[1] ? na : color.new(c_hist_sup, 20)

zz_resistance := zzRes
zz_support    := zzSup

[zzHH, zzHL, zzLH, zzLL] = zz.getHHLL(zzSwingH, zzSwingL)
[zzBiasNow, zzBullBiasRaw, zzBearBiasRaw] = zz.getStructureBias(zzHH, zzHL, zzLH, zzLL)
zz_struct_bias := zzBiasNow

// Professional liquidity sweep detection:
// raw raid -> reclaim/rejection -> displacement validation -> per-level cooldown.
[zzBullSweepNow, zzBearSweepNow, zzBullSweepRawNow, zzBearSweepRawNow, zzBullSweepPendingNow, zzBearSweepPendingNow] = zz.getProfessionalLiquiditySweep(
    zzRes, zzSup, zz_sweep_thresh, liq_sweep_min_pen_atr, liq_sweep_displacement_atr,
    liq_sweep_confirm_bars, liq_sweep_cooldown_bars, zz_atr_len, liq_sweep_body_reclaim)
zz_bull_sweep := zzBullSweepNow
zz_bear_sweep := zzBearSweepNow
zz_bull_sweep_raw := zzBullSweepRawNow
zz_bear_sweep_raw := zzBearSweepRawNow
zz_bull_sweep_pending := zzBullSweepPendingNow
zz_bear_sweep_pending := zzBearSweepPendingNow

bars_since_fa_bull = ta.barssince(failed_auction_bull)
bars_since_fa_bear = ta.barssince(failed_auction_bear)
bars_since_sweep_bull = ta.barssince(zz_bull_sweep)
bars_since_sweep_bear = ta.barssince(zz_bear_sweep)
bool recent_fa_bull = failed_auction_bull or (not na(bars_since_fa_bull) and bars_since_fa_bull <= liq_sweep_confirm_bars)
bool recent_fa_bear = failed_auction_bear or (not na(bars_since_fa_bear) and bars_since_fa_bear <= liq_sweep_confirm_bars)
bool recent_sweep_bull = zz_bull_sweep or (not na(bars_since_sweep_bull) and bars_since_sweep_bull <= fa_confirm_bars)
bool recent_sweep_bear = zz_bear_sweep or (not na(bars_since_sweep_bear) and bars_since_sweep_bear <= fa_confirm_bars)

// High-conviction: validated structural sweep AND confirmed failed auction inside the validation window.
zz_high_conv_bull := show_zz_sweep and recent_sweep_bull and recent_fa_bull and (zz_bull_sweep or failed_auction_bull)
zz_high_conv_bear := show_zz_sweep and recent_sweep_bear and recent_fa_bear and (zz_bear_sweep or failed_auction_bear)

// =========================================================================
// v9.3: BOS / CHoCH + STRUCTURE SCORES
// =========================================================================
// getBOSCHOCH has var state internally — must run every bar at top scope.
// zz_bos_confirm_candles is simple int (input), zz_struct_bias is int — both valid.
[zzBullBOSNow, zzBearBOSNow, zzBullCHoCHNow, zzBearCHoCHNow] = zz.getBOSCHOCH(
    zzRes, zzSup, zz_struct_bias, zz_bos_confirm_candles, zz_use_body_break)
zz_bull_bos   := zzBullBOSNow
zz_bear_bos   := zzBearBOSNow
zz_bull_choch := zzBullCHoCHNow
zz_bear_choch := zzBearCHoCHNow

// Structure quality scores — ta.atr() inside, must run unconditionally at top scope.
// Returns 0-100: 35=bias, 30=price location vs EQ/S/R, 30=swing range vs ATR.
zz_score_long  := zz.getStructureScore(zzRes, zzSup, zz_struct_bias, true,  zz_atr_len, close)
zz_score_short := zz.getStructureScore(zzRes, zzSup, zz_struct_bias, false, zz_atr_len, close)

// =========================================================================
// v9.2 [2]: DELTA STRENGTH
// =========================================================================
delta_strength := show_delta_strength ? f_delta_strength(eff_delta_len) : 0.0

// =========================================================================
// v9.2 [3]: SMART MONEY DIVERGENCE
// =========================================================================
// Unpack into fresh locals, then assign to var bools
// v9.8.0: eff_smd_lookback replaces smd_lookback (~50 min equivalent)
[smdAccumNow, smdDistNow] = f_smart_money_div(eff_smd_lookback, current_atr)

// v9.9.1 PATCH #13: SMD VA boundary filter.
// f_smart_money_div fires on ANY bar where price moved with declining volume —
// completely location-blind. Distribution (price rising, thin vol) only has
// meaning when price is pushing into or above VAH — a breakout attempt with
// no institutional conviction behind it. Price rising from VAL to mid-range
// on thin volume is a weak bounce, NOT distribution.
// Accumulation (price falling, thin vol) is only meaningful at/below VAL.
// Gate: close must be within 0.5 ATR of the boundary (or beyond it).
// Falls back to unfiltered if VA not yet established.
bool _smd_near_vah = na(session_state.vah) or close >= session_state.vah - current_atr * 0.5
bool _smd_near_val = na(session_state.val) or close <= session_state.val + current_atr * 0.5
smd_distribution := smdDistNow  and _smd_near_vah
smd_accumulation := smdAccumNow and _smd_near_val

// =========================================================================
// REAL-TIME POC CALCULATION
// =========================================================================
if enable_realtime_poc and execute_now
    if session_state.vol_map.size() > 0
        float  max_vol_live = 0.0
        int    max_vol_key  = na
        for [key, vol_at_key] in session_state.vol_map
            if vol_at_key > max_vol_live
                max_vol_live := vol_at_key
                max_vol_key  := key
        if not na(max_vol_key)
            live_poc := binning.f_get_price_from_index(max_vol_key, session_state.bin_size)

if barstate.isconfirmed
    confirmed_poc := session_state.poc

float active_poc = enable_realtime_poc ? (na(live_poc) ? session_state.poc : live_poc) : session_state.poc

// =========================================================================
// MARKET STATE INTELLIGENCE
// =========================================================================
string prev_market_state = current_market_state

if show_market_state
    if zz_high_conv_bull or zz_high_conv_bear
        // Highest priority: both ZZ structural sweep AND failed auction agree
        current_market_state       := "SWEEP+FA"
        current_market_state_color := zz_high_conv_bull ? color.new(color.lime, 0) : color.new(color.red, 0)
    else if zz_bull_choch or zz_bear_choch
        // CHoCH = trend reversal signal — higher significance than a sweep alone
        current_market_state       := "CHoCH"
        current_market_state_color := zz_bull_choch ? color.rgb(0, 230, 118) : color.rgb(234, 0, 255)
    else if (show_zz_sweep and zz_bull_sweep) or (show_zz_sweep and zz_bear_sweep)
        current_market_state       := "ZZ SWEEP"
        current_market_state_color := zz_bull_sweep ? color.new(color.lime, 30) : color.new(color.red, 30)
    else if zz_bull_bos or zz_bear_bos
        current_market_state       := "BOS"
        current_market_state_color := zz_bull_bos ? color.new(color.teal, 0) : color.new(color.orange, 0)
    else if failed_auction_bear or failed_auction_bull
        current_market_state       := "FAILED AUCTION"
        current_market_state_color := color.fuchsia
    else if exhaustion_signal
        current_market_state       := "EXHAUSTION"
        current_market_state_color := color.orange
    else if iceberg_detected
        current_market_state       := "ICEBERG"
        current_market_state_color := color.purple
    else if absorption_signal
        current_market_state       := "ABSORPTION"
        current_market_state_color := color.yellow
    else if smd_distribution and show_smd_on_imb
        current_market_state       := "DISTRIBUTION"
        current_market_state_color := color.orange
    else if smd_accumulation and show_smd_on_imb
        current_market_state       := "ACCUMULATION"
        current_market_state_color := color.teal
    else if bearish_div or bullish_div
        current_market_state       := "DIVERGENCE"
        current_market_state_color := color.fuchsia
    else if math.abs(rotation_factor) > 0.3
        current_market_state       := "TRENDING"
        current_market_state_color := color.lime
    else
        current_market_state       := "ROTATING"
        current_market_state_color := color.aqua

    if current_market_state != prev_market_state
        market_state_changes += 1

// =========================================================================
// ORDER FLOW VISUALIZATION — POC GHOST TRAILS
// =========================================================================
if show_ghost_trails and not na(session_state.poc) and barstate.isconfirmed
    // Option 1 — Momentum filter: only draw when POC has accumulated at least
    // ghost_atr_filter × ATR of movement since the LAST DRAWN segment.
    //
    // CRITICAL FIX v9.4: last_poc_price must only update on a drawn segment.
    // Previous logic updated it every bar, which reset the accumulation window
    // and made the comparison bar-to-bar instead of segment-to-segment.
    // On 1m/5m/15m, POC barely moves between consecutive bars — the bar-to-bar
    // delta never cleared the threshold, so nothing ever drew.
    // Now: seed on first bar of session (no draw), then accumulate movement
    // until threshold is crossed, draw, and reset the seed to the new position.
    // ✅ v9.4.1 FIX: Timeframe-adaptive ghost trail threshold
    // Base ATR filter is adjusted per timeframe so trails appear consistently across all TFs
    float tf_adapter = timeframe.isintraday ? (timeframe.multiplier <= 5 ? 0.3 : timeframe.multiplier <= 15 ? 0.5 : timeframe.multiplier <= 60 ? 0.7 : 1.0) : 1.0
    float ghost_threshold = ta.atr(zz_atr_len) * ghost_atr_filter * tf_adapter
    if na(last_poc_price)
        // First confirmed bar after session reset — seed tracking, no trail
        last_poc_price := session_state.poc
        last_poc_bar   := bar_index
    else
        bool poc_moved = math.abs(session_state.poc - last_poc_price) >= ghost_threshold
        if poc_moved and bar_index > last_poc_bar + 1
            color ghost_col = c_ghost_stationary
            if use_colored_ghost
                if session_state.poc > last_poc_price
                    ghost_col := c_ghost_rising
                else if session_state.poc < last_poc_price
                    ghost_col := c_ghost_falling
            line ghost_line = line.new(last_poc_bar, last_poc_price, bar_index, session_state.poc,
                color=ghost_col, width=1, style=line.style_solid)
            array.push(ghost_trail_lines, ghost_line)
            // Only update seed on draw — preserves accumulated delta for next segment
            last_poc_price := session_state.poc
            last_poc_bar   := bar_index

// =========================================================================
// VA GHOST CLOUD — ADAPTIVE TILE RING BUFFER  ✅ RESTORED v9.6.0
// =========================================================================
// v9.5.x replaced the tile trail with a single stretching box to fix the
// 500-box overflow. That eliminated the core trading behavior: a historical
// trail showing where the VA has been, with price-exit color signaling
// breakouts in real time. The restored version keeps a tighter tile/profile
// budget so the trail stays inside TradingView's 500-box ceiling.
//
// TRADING SIGNAL: When price exits the VA, tile color flips to lime (above
// VAH) or red (below VAL) — flagging high-probability continuation setups
// the moment the breakout happens, bar by bar.
//
// BUDGET: MAX_CLOUD_TILES=100 tiles + hard caps on LVN/FL/Imb + FVG prune
// + profile cleanup keeps the object set inside the legal 500-box ceiling.
// =========================================================================
if show_va_cloud and not na(session_state.vah) and not na(session_state.val)

    // ── Tile cap — adjust lower (60) if adding more box-heavy features ───
    int MAX_CLOUD_TILES = 100

    // ── Adaptive spawn interval ─────────────────────────────────────────
    // Recalculates each bar so interval grows as session ages, keeping
    // total tiles under cap regardless of session length or timeframe.
    // v9.8.1 FIX: TF-aware minimum interval prevents all tiles front-loading
    // at session open on higher TFs where confirmed bars are scarce.
    // Without this floor, spawn_interval stays 1 for the entire session on
    // 15m/1h (session has <100 bars) so every early bar spawns a tile — then
    // the ring buffer churns and discards them all, leaving only recent tiles.
    int session_age    = bar_index - session_state.start_bar

    // v9.8.2 ADAPTIVE FIX: spawn_interval driven by actual session length.
    //
    // Denominator = max(prev_session_bars, session_age + 1):
    //   - prev_session_bars: calibrated from last completed session (or smart
    //     bootstrap from sessionType+TF on bar 0). Handles session-start correctly.
    //   - session_age + 1: adapts mid-session if the current session runs LONGER
    //     than the previous one (e.g. first Daily session after switching from RTH).
    //     Prevents spawn_interval from staying too small and churning the ring buffer.
    //
    // Results vs old tf_min_interval approach:
    //   NQ RTH   1h  (7 bars)  : OLD=5 → 2 tiles  |  NEW=1 → 7 tiles
    //   NQ RTH   5m  (81 bars) : OLD=2 → 40 tiles |  NEW=1 → 81 tiles
    //   NQ RTH  15m  (27 bars) : OLD=3 → 9 tiles  |  NEW=1 → 27 tiles
    //   SOL Daily 1h (24 bars) : OLD=5 → 4 tiles  |  NEW=1 → 24 tiles
    //   SOL Daily 5m (288 bars): OLD=2 → 96 tiles |  NEW=3 → 96 tiles
    //   SOL Daily 1m (1440 bars): OLD=14→ 102 tiles|  NEW=14→ 102 tiles
    int eff_sess_len   = math.max(prev_session_bars, session_age + 1)
    int spawn_interval = math.max(1, math.round(float(eff_sess_len) / float(MAX_CLOUD_TILES)))

    // ── Delta-tinted base color ─────────────────────────────────────────
    // ✅ v9.6.0 FIX 4: color.silver → rgb(140,160,200) — holds visual weight
    // at 75% transparency on dark AND light chart themes.
    // v9.8.1 FIX: color.orange → rgb(180,140,60) for Neutral state.
    // color.orange at 75% transparency is near-invisible on dark themes
    // (renders as washed-out pale yellow). The higher-saturation amber holds
    // visual weight at 75% transp and is clearly distinguishable from Stable.
    color base_col = va_state == "Expanding"   ? color.blue
                   : va_state == "Contracting" ? color.red
                   : va_state == "Stable"      ? color.rgb(140, 160, 200)
                   : color.rgb(180, 140, 60)   // "Neutral" — early session, VA not yet measured

    if va_cloud_delta_tint and session_state.total_volume > 0
        float dp = of.calculate_flow_pressure(session_state.total_buy, session_state.total_sell)
        if dp > 20
            base_col := va_state == "Expanding" ? color.new(color.teal, 0) : color.green
        else if dp < -20
            base_col := va_state == "Contracting" ? color.maroon : color.red

    // ── Price-exit color override ───────────────────────────────────────
    // CORE TRADING SIGNAL: tiles flip color when price exits the VA.
    // Lime = price above VAH (bullish breakout). Red = price below VAL.
    bool price_inside = close >= session_state.val and close <= session_state.vah
    if not price_inside
        base_col := close > session_state.vah ? color.new(color.lime, 0)
                                              : color.new(color.red,  0)

    // ── VA reclaim / rejection border on the live tile ──────────────────
    color border_col = color.new(color.white, 100)
    int   border_w   = 0
    if show_va_reclaim_border
        if price_inside and not prev_price_inside_va
            border_col := color.new(color.lime, 20)
            border_w   := 2
        else if not price_inside and prev_price_inside_va
            border_col := color.new(color.red, 20)
            border_w   := 2

    prev_price_inside_va := price_inside

    // ── Fixed transparency ──────────────────────────────────────────────
    // Single tiles must be more opaque than the old stacked approach.
    // v9.8.1 FIX: Neutral state drops to 55% transp (more opaque) since it
    // only exists early in the session before VA is measured — making those
    // first tiles visible is critical. All other states stay at 75%.
    color cloud_fill = color.new(base_col, va_state == "Neutral" ? 55 : 75)

    // ── Spawn historical tile on interval ───────────────────────────────
    // Locks the VAH/VAL at the moment of spawn — forms the historical trail.
    // v9.8.1 FIX: Added fallback condition — if no historical tiles exist yet
    // (array is empty) and session_age > 0, force a spawn. Without this, the
    // first tile waits for the first modulo hit which on higher TF-min-intervals
    // (e.g. tf_min_interval=5 on 1h) means no tile for the first 5 confirmed
    // bars — and if the live tile is invisible (Neutral state), nothing shows.
    bool spawn_now = barstate.isconfirmed and
         (session_age % spawn_interval == 0 or
          (session_age > 0 and array.size(va_cloud_boxes) == 0))

    if spawn_now
        // FIFO ring buffer — delete oldest tile if at cap
        if array.size(va_cloud_boxes) >= MAX_CLOUD_TILES
            box oldest = array.shift(va_cloud_boxes)
            box.delete(oldest)

        box new_tile = box.new(
            bar_index - spawn_interval, session_state.vah,
            bar_index,                  session_state.val,
            border_color = color.new(color.white, 100),
            border_width = 0,
            bgcolor      = cloud_fill)
        array.push(va_cloud_boxes, new_tile)

    // ── Live tile — covers gap from last spawn to current bar ───────────
    // Updated every bar so it always tracks the developing VA in real time.
    // Sits on top of the historical trail. This is what shows live VA drift.
    // FIX: Clamp to session_state.start_bar. Without this, on bars where
    // session_age % spawn_interval > 0 the left edge reaches back into the
    // previous session, causing the live tile to visually bleed across the
    // session boundary on higher timeframes.
    int live_left = math.max(session_state.start_bar, bar_index - (session_age % spawn_interval))
    if na(active_va_cloud)
        active_va_cloud := box.new(
            live_left,     session_state.vah,
            bar_index + 1, session_state.val,
            border_color = border_col,
            border_width = border_w,
            bgcolor      = cloud_fill)
    else
        box.set_left(active_va_cloud,         live_left)
        box.set_top(active_va_cloud,          session_state.vah)
        box.set_right(active_va_cloud,        bar_index + 1)
        box.set_bottom(active_va_cloud,       session_state.val)
        box.set_bgcolor(active_va_cloud,      cloud_fill)
        box.set_border_color(active_va_cloud, border_col)
        box.set_border_width(active_va_cloud, border_w)


// =========================================================================
// ENHANCED BUBBLE SYSTEM
// =========================================================================
if show_bubbles and barstate.isconfirmed
    if array.size(active_bubbles) > 0
        for i = array.size(active_bubbles) - 1 to 0
            if i >= 0 and i < array.size(active_bubbles)
                bubbles.BubbleData bubble = array.get(active_bubbles, i)
                if (bar_index - bubble.bar_idx) > eff_bubble_age
                    label.delete(bubble.bubble_label)
                    array.remove(active_bubbles, i)

    if enable_smart_pruning and array.size(active_bubbles) > max_bubbles
        // v9.8.0: eff_bubble_prox (ATR × 0.12) replaces mintick × ticks — instrument-adaptive
        float prox_threshold = eff_bubble_prox
        for i = array.size(active_bubbles) - 1 to 0
            if array.size(active_bubbles) <= max_bubbles
                break
            if i >= 0 and i < array.size(active_bubbles)
                bubbles.BubbleData bubble = array.get(active_bubbles, i)
                bool near_poc = not na(session_state.poc) ? math.abs(bubble.price_level - session_state.poc) < prox_threshold : false
                bool near_vah = not na(session_state.vah) ? math.abs(bubble.price_level - session_state.vah) < prox_threshold : false
                bool near_val = not na(session_state.val) ? math.abs(bubble.price_level - session_state.val) < prox_threshold : false
                if not near_poc and not near_vah and not near_val
                    label.delete(bubble.bubble_label)
                    array.remove(active_bubbles, i)

    float vol_mean      = ta.sma(volume, 20)
    float vol_std       = ta.stdev(volume, 20)

    // v9.8.0: eff_bubble_min_delta (5% of avg bar delta) replaces raw 50-contract floor
    bubbles.BubbleConfig config = bubbles.new_config(
        eff_bubble_vol_thresh, eff_bubble_min_delta, bubble_size_mode,
        bubble_show_ratio, max_bubbles, bubble_offset,
        bullCol, bearCol, bubble_color_mode, bubble_tier_strength)

    if bubbles.should_create_bubble(volume, vol_mean, vol_std, current_bar_delta, config)
        var float[] recent_deltas = array.new<float>()
        recent_deltas.unshift(current_bar_delta)
        if recent_deltas.size() > 20
            recent_deltas.pop()
        float max_recent_delta = bubbles.get_max_recent_delta(recent_deltas)

        bubbles.BubbleData new_bubble = bubbles.create_bubble(
            config, bar_index, high, low,
            session_state.total_buy, session_state.total_sell,
            volume, vol_mean, vol_std, max_recent_delta)

        if show_bubble_tooltips
            float z_score_calc = vol_std > 0 ? (volume - vol_mean) / vol_std : 0
            string tooltip = bubbles.build_tooltip(
                new_bubble.delta_value, new_bubble.buy_vol, new_bubble.sell_vol,
                new_bubble.volume_value, z_score_calc, new_bubble.price_level)
            label.set_tooltip(new_bubble.bubble_label, tooltip)

        bubbles.manage_bubble_array(active_bubbles, new_bubble, max_bubbles)

// Map pruning
if enable_pruning and bar_index % 100 == 0 and not na(session_state.poc)
    binning.pruneOutliers(session_state.vol_map, session_state.buy_map, session_state.sell_map,
        session_state.poc, session_state.bin_size, prune_stdev)

// Performance monitoring
if enable_performance_monitoring and barstate.islast and bar_index % 50 == 0
    // AUDIT FIX 3: Expanded object count — reflects real drawing pressure
    // across all active arrays, not just profile_boxes + level_lines + session_labels.
    // box_limit=500 matches TradingView's legal max_boxes_count ceiling.
    int _total_box_count = array.size(profile_boxes) + array.size(lvn_boxes) + array.size(fast_lane_boxes) + array.size(imbalance_zones) + array.size(va_cloud_boxes) + array.size(fvg_array) * 2 + array.size(ifvg_array) * 2 + (not na(active_va_cloud) ? 1 : 0) + (not na(prior_va_ref_box) ? 1 : 0)
    int _total_line_count = array.size(level_lines) + array.size(ghost_trail_lines) + array.size(ms_zz_lines) + array.size(ms_hist_res_lines) + array.size(ms_hist_sup_lines) + (not na(prior_vah_line) ? 1 : 0) + (not na(prior_val_line) ? 1 : 0) + (not na(prior_poc_line) ? 1 : 0) + (not na(ms_res_line) ? 1 : 0) + (not na(ms_sup_line) ? 1 : 0) + (not na(ms_eq_line) ? 1 : 0)
    int _total_label_count = array.size(session_labels) + array.size(pattern_labels) + array.size(active_bubbles) + array.size(ms_hhll_labels) + array.size(ms_bos_labels) + array.size(ms_hist_res_labels) + array.size(ms_hist_sup_labels) + array.size(ifvg_array) + (not na(current_session_label) ? 1 : 0) + (not na(prior_va_status_label) ? 1 : 0) + (not na(ms_res_label) ? 1 : 0) + (not na(ms_sup_label) ? 1 : 0) + (not na(ms_eq_label) ? 1 : 0)
    // AUDIT: Published GodTier_Optimization/6 supports explicit object
    // limits, so use the actual declared 500/500/500 ceilings directly.
    memory_usage := opt.estimate_memory_usage(_total_box_count, _total_line_count, _total_label_count, 500, 500, 500)
    // AUDIT FIX 4: Expanded emergency cleanup — prunes all major non-critical
    // arrays, not just profile_boxes + level_lines. Preserves active_va_cloud and
    // live swing lines. Deletion is via array.shift() (oldest first) to avoid index gaps.
    if memory_usage > emergency_threshold
        bool _did_cleanup = false
        if opt.emergency_cleanup(profile_boxes, level_lines, emergency_threshold)
            _did_cleanup := true
        int _prune_lvn  = math.round(array.size(lvn_boxes)       * 0.3)
        int _prune_fl   = math.round(array.size(fast_lane_boxes)  * 0.3)
        int _prune_imb  = math.round(array.size(imbalance_zones)  * 0.3)
        int _prune_pat  = math.round(array.size(pattern_labels)   * 0.3)
        int _prune_ms   = math.round(array.size(ms_hhll_labels)   * 0.3)
        int _prune_bos  = math.round(array.size(ms_bos_labels)    * 0.3)
        if _prune_lvn > 0
            for _i = 0 to _prune_lvn - 1
                if array.size(lvn_boxes) > 0
                    box.delete(array.shift(lvn_boxes))
                    _did_cleanup := true
        if _prune_fl > 0
            for _i = 0 to _prune_fl - 1
                if array.size(fast_lane_boxes) > 0
                    box.delete(array.shift(fast_lane_boxes))
                    _did_cleanup := true
        if _prune_imb > 0
            for _i = 0 to _prune_imb - 1
                if array.size(imbalance_zones) > 0
                    box.delete(array.shift(imbalance_zones))
                    _did_cleanup := true
        if _prune_pat > 0
            for _i = 0 to _prune_pat - 1
                if array.size(pattern_labels) > 0
                    label.delete(array.shift(pattern_labels))
                    _did_cleanup := true
        if _prune_ms > 0
            for _i = 0 to _prune_ms - 1
                if array.size(ms_hhll_labels) > 0
                    label.delete(array.shift(ms_hhll_labels))
                    _did_cleanup := true
        if _prune_bos > 0
            for _i = 0 to _prune_bos - 1
                if array.size(ms_bos_labels) > 0
                    label.delete(array.shift(ms_bos_labels))
                    _did_cleanup := true
        int _cloud_before = array.size(va_cloud_boxes)
        f_prune_boxes(va_cloud_boxes, 50)
        if array.size(va_cloud_boxes) < _cloud_before
            _did_cleanup := true
        int _hist_res_before = array.size(ms_hist_res_lines)
        int _hist_sup_before = array.size(ms_hist_sup_lines)
        f_prune_lines(ms_hist_res_lines,  math.max(1, math.floor(hist_sr_max_levels * 0.7)))
        f_prune_labels(ms_hist_res_labels, math.max(1, math.floor(hist_sr_max_levels * 0.7)))
        f_prune_lines(ms_hist_sup_lines,  math.max(1, math.floor(hist_sr_max_levels * 0.7)))
        f_prune_labels(ms_hist_sup_labels, math.max(1, math.floor(hist_sr_max_levels * 0.7)))
        if array.size(ms_hist_res_lines) < _hist_res_before or array.size(ms_hist_sup_lines) < _hist_sup_before
            _did_cleanup := true
        if _did_cleanup
            emergency_cleanup_triggered := true

// =========================================================================
// v9.4: FAIR VALUE GAPS + INVERSE FVGs  (GodTier_FVG library)
// =========================================================================
// Detection, split-box rendering, partial-fill tracking, IFVG polarity
// flip, and mitigation scanning all delegated to GodTier_FVG v1.0.
// Main indicator owns the var arrays; library functions mutate by reference.
// ─────────────────────────────────────────────────────────────────────────

// CRITICAL FIX v9.4: barstate.isconfirmed guard added.
// Without it, detect+spawn runs on every realtime tick. On 1m/5m/15m,
// scan_mitigation immediately kills newly spawned FVGs if close has
// moved past the gap mid-bar, causing FVGs to flash and die before
// the bar confirms. Now all FVG operations run only on closed bars.
// FIX: Guard session_bar_count >= 3. On bars 0–2 of a new session, time[2]
// still points into the previous session. Any FVG detected on bar 2 would
// have its left edge (start_t = time[2]) anchored in the prior session,
// drawing a box that visually spans the session boundary.
if show_fvg and barstate.isconfirmed and session_bar_count >= 3
    // ── Detect ──────────────────────────────────────────────────────────
    [bull_fvg, bear_fvg, bull_str, bear_str, vol_spk, _atr] = fvg_lib.detect(14, fvg_threshold)

    // ── Spawn new FVGs ───────────────────────────────────────────────────
    // v9.8.0: eff_fvg_extend replaces fvg_extend_bars (~100 min equivalent)
    // v9.9: gate_fvg() — requires L1≥40, L3≥35, not RANGING_NOISE. Refactored to pass direction.
    if bull_fvg and (na(cie_state) or cie_state.gate_fvg(1))
        fvg_lib.spawn_fvg(fvg_array, 1, low, high[2],
             bull_str, vol_spk, c_fvg_bull, c_fvg_bear,
             eff_fvg_extend, fvg_max_active)

    if bear_fvg and (na(cie_state) or cie_state.gate_fvg(-1))
        fvg_lib.spawn_fvg(fvg_array, -1, low[2], high,
             bear_str, vol_spk, c_fvg_bull, c_fvg_bear,
             eff_fvg_extend, fvg_max_active)

    // ── Mitigation scan + IFVG spawning ─────────────────────────────────
    [_mit_n, _ifvg_n] = fvg_lib.scan_mitigation(
         fvg_array, ifvg_array, show_ifvg,
         c_fvg_bull, c_fvg_bear, c_ifvg_bull, c_ifvg_bear,
         eff_fvg_extend, fvg_max_active)

    // ── IFVG invalidation scan ───────────────────────────────────────────
    if show_ifvg
        fvg_lib.scan_ifvg_mitigation(ifvg_array, c_ifvg_bull, c_ifvg_bear)

// =========================================================================
// v9.9: IFVG FLIP DETECTION (for CIE L4 Liquidity layer)
// ─────────────────────────────────────────────────────────────────────────
// Compare ifvg_array size this bar vs last bar. If size grew, a new IFVG
// was spawned this bar = polarity flip event. Check newest element's .bias
// to determine flip direction. spawn_ifvg() uses array.unshift() so newest
// is always at index 0. Guard on barstate.isconfirmed to avoid mid-bar fires.
// =========================================================================
ifvg_flip_bull := false
ifvg_flip_bear := false
// v9.9.1 PATCH #6: Split display gate from state tracking.
// ifvg_count_prev must update every confirmed bar regardless of show_fvg.
// If show_fvg is toggled off, the array still accumulates — freezing prev
// causes a false ifvg_flip event (large count delta) when show_fvg re-enables,
// feeding a spurious L4 signal to CIE analyze_context().
if barstate.isconfirmed
    int cur_ifvg_count = array.size(ifvg_array)
    if show_fvg and cur_ifvg_count > ifvg_count_prev
        fvg_lib.InverseFVG newest_ifvg = array.get(ifvg_array, 0)
        // bias == 1  → bullish IFVG (bear FVG mitigated → flipped to support)
        // bias == -1 → bearish IFVG (bull FVG mitigated → flipped to resistance)
        ifvg_flip_bull := newest_ifvg.bias == 1
        ifvg_flip_bear := newest_ifvg.bias == -1
    // Always sync prev count — state tracking is not display-gated
    ifvg_count_prev := cur_ifvg_count

// =========================================================================
// v9.9: STACKED IMBALANCE COUNT (feeds CIE L3 Order Flow layer)
// ─────────────────────────────────────────────────────────────────────────
// v9.9.1 PATCH #16: Replaced find_stacked_imbalances (raw total count) with
// find_imbalance_zones + boundary filter. The old approach counted ALL stacked
// clusters across the entire vol_map — mid-VA imbalance clusters from historical
// trading concentration were feeding the CIE as if they were institutional signals.
// Only imbalance zones at or near VAH, VAL, or POC boundaries matter: those are
// the walls and magnets that drive price. Mid-range clusters are just noise.
// Bin tolerance of 3 accounts for ATR drift and dynamic bin granularity changes.
// Falls back to old raw count if VA not yet established (session warmup).
// =========================================================================
// v9.9.3 PATCH #30: show_stacked_imb removed from count gate.
// stacked_imb_count feeds CIE L3 — it is data, not a display flag.
// show_stacked_imb gates the box rendering only (handled at render site).
int stacked_imb_count = 0
if map.size(session_state.buy_map) > 3
    if na(session_state.vah) or na(session_state.val) or na(session_state.bin_size)
        // VA not yet established — use raw count as fallback
        stacked_imb_count := of.find_stacked_imbalances(session_state.buy_map, session_state.sell_map, eff_imbalance_ratio)
    else
        int _vah_bin   = binning.f_get_bin_index(session_state.vah, session_state.bin_size)
        int _val_bin   = binning.f_get_bin_index(session_state.val, session_state.bin_size)
        int _poc_bin   = binning.f_get_bin_index(session_state.poc, session_state.bin_size)
        int _bin_tol   = 3
        of.ImbalanceZone[] _zones = of.find_imbalance_zones(
            session_state.buy_map, session_state.sell_map, eff_imbalance_ratio)
        for _zone in _zones
            bool _near_vah = math.abs(_zone.start_idx - _vah_bin) <= _bin_tol or math.abs(_zone.end_idx - _vah_bin) <= _bin_tol
            bool _near_val = math.abs(_zone.start_idx - _val_bin) <= _bin_tol or math.abs(_zone.end_idx - _val_bin) <= _bin_tol
            bool _near_poc = math.abs(_zone.start_idx - _poc_bin) <= _bin_tol or math.abs(_zone.end_idx - _poc_bin) <= _bin_tol
            if _near_vah or _near_val or _near_poc
                stacked_imb_count += 1


// v9.9.4 Phase 1: Update Prior VA Interaction Counters (runs every bar)
if not na(prior_session_vah) and not na(prior_session_val)
    if close > prior_session_vah
        prior_va_close_above += 1
    else if close < prior_session_val
        prior_va_close_below += 1
    else
        prior_va_close_inside += 1
    
    // Touch counters track level interactions, independent of final acceptance.
    if high >= prior_session_vah and low <= prior_session_vah
        prior_va_touch_vah += 1
    if high >= prior_session_val and low <= prior_session_val
        prior_va_touch_val += 1
    
    // NPOC Tested Logic (5-tick tolerance)
    if not na(prior_session_poc) and not prior_va_poc_tested
        float _poc_tol = syminfo.mintick * 5
        if low <= prior_session_poc + _poc_tol and high >= prior_session_poc - _poc_tol
            prior_va_poc_tested := true

    // Phase 2: Dynamic Visual Updates (Runs Every Bar)
    if show_prior_va and not na(prior_va_ref_box)
        // Background Tinting based on price orientation
        color _bg = close > prior_session_vah ? color.new(color.green, 95) :
                   close < prior_session_val ? color.new(color.red, 95) :
                   color.new(c_prior_va, 90)
        box.set_bgcolor(prior_va_ref_box, _bg)
        box.set_right(prior_va_ref_box, bar_index + 20)
        
        // Interaction Line State Management
        if not na(prior_vah_line)
            line.set_x2(prior_vah_line, bar_index + 20)
            if prior_va_touch_vah >= 2 and prior_va_close_above <= 1
                line.set_color(prior_vah_line, color.new(color.red, 20))
                line.set_width(prior_vah_line, 2)
            else if prior_va_close_above >= 3
                line.set_color(prior_vah_line, color.new(color.lime, 20))

        if not na(prior_val_line)
            line.set_x2(prior_val_line, bar_index + 20)
            if prior_va_touch_val >= 2 and prior_va_close_below <= 1
                line.set_color(prior_val_line, color.new(color.green, 20))
                line.set_width(prior_val_line, 2)
            else if prior_va_close_below >= 3
                line.set_color(prior_val_line, color.new(color.red, 20))

        if not na(prior_poc_line)
            line.set_x2(prior_poc_line, bar_index + 20)
            if prior_va_poc_tested and not na(prior_va_status_label)
                label.set_text(prior_va_status_label, "POC TESTED")
                label.set_textcolor(prior_va_status_label, color.new(color.lime, 40))
                label.set_x(prior_va_status_label, bar_index + 5)
        
        // Acceptance/Rejection Status Labels (Fires once per event)
        // AUDIT: Labels now tracked in pattern_labels for FIFO pruning.
        // Previously created with label.new() but never tracked — leaked.
        if barstate.isconfirmed
            if prior_va_close_inside == 3
                label _acc_lbl = label.new(bar_index, (prior_session_vah + prior_session_val)/2, "⚙ Accepted",
                    color=color.new(color.black, 100), textcolor=color.lime, style=label.style_label_center, size=size.small)
                array.push(pattern_labels, _acc_lbl)
            else if prior_va_touch_vah == 2 and prior_va_close_above == 0
                label _rej_lbl = label.new(bar_index, prior_session_vah, "⬇ Rejected",
                    color=color.new(color.black, 100), textcolor=color.red, style=label.style_label_down, size=size.small)
                array.push(pattern_labels, _rej_lbl)
            else if prior_va_touch_val == 2 and prior_va_close_below == 0
                label _rej_lbl = label.new(bar_index, prior_session_val, "⬆ Rejected",
                    color=color.new(color.black, 100), textcolor=color.green, style=label.style_label_up, size=size.small)
                array.push(pattern_labels, _rej_lbl)

// =========================================================================
// v9.3 SR PATCH: S/R Live Extension + Historical Mitigation (every bar)
// =========================================================================

// ── Live S/R line extension ────────────────────────────────────────────────
// Keeps ms_res_line, ms_sup_line, ms_eq_line extending to bar_index + 50
// every bar so they track price in real time, not only on barstate.islast.
if show_market_structure and show_swing_levels
    if not na(ms_res_line)
        line.set_x2(ms_res_line, bar_index + 50)
    if show_sr_price_labels and not na(ms_res_label)
        label.set_x(ms_res_label, bar_index + 50)

    if not na(ms_sup_line)
        line.set_x2(ms_sup_line, bar_index + 50)
    if show_sr_price_labels and not na(ms_sup_label)
        label.set_x(ms_sup_label, bar_index + 50)

    if show_equilibrium and not na(ms_eq_line)
        line.set_x2(ms_eq_line, bar_index + 50)
    if show_equilibrium and show_sr_price_labels and not na(ms_eq_label)
        label.set_x(ms_eq_label, bar_index + 50)

// ── Historical line + label extension ─────────────────────────────────────
if show_market_structure and show_hist_sr_levels
    int hist_res_sz = array.size(ms_hist_res_lines)
    if hist_res_sz > 0
        for i = 0 to hist_res_sz - 1
            line hl = array.get(ms_hist_res_lines, i)
            if not na(hl)
                line.set_x2(hl, bar_index + 50)
            if show_sr_price_labels and i < array.size(ms_hist_res_labels)
                label hlb = array.get(ms_hist_res_labels, i)
                if not na(hlb)
                    label.set_x(hlb, bar_index + 50)

    int hist_sup_sz = array.size(ms_hist_sup_lines)
    if hist_sup_sz > 0
        for i = 0 to hist_sup_sz - 1
            line hl = array.get(ms_hist_sup_lines, i)
            if not na(hl)
                line.set_x2(hl, bar_index + 50)
            if show_sr_price_labels and i < array.size(ms_hist_sup_labels)
                label hlb = array.get(ms_hist_sup_labels, i)
                if not na(hlb)
                    label.set_x(hlb, bar_index + 50)

// ── Mitigation — close-through deletion ───────────────────────────────────
if show_market_structure and show_hist_sr_levels and show_sr_mitigation and barstate.isconfirmed
    int n_res = array.size(ms_hist_res_lines)
    if n_res > 0
        for i = n_res - 1 to 0
            if i < array.size(ms_hist_res_lines)
                line ln   = array.get(ms_hist_res_lines, i)
                float lvl = not na(ln) ? line.get_y1(ln) : na
                if not na(lvl) and close > lvl
                    line.delete(ln)
                    array.remove(ms_hist_res_lines, i)
                    if show_sr_price_labels and i < array.size(ms_hist_res_labels)
                        label.delete(array.get(ms_hist_res_labels, i))
                        array.remove(ms_hist_res_labels, i)

    int n_sup = array.size(ms_hist_sup_lines)
    if n_sup > 0
        for i = n_sup - 1 to 0
            if i < array.size(ms_hist_sup_lines)
                line ln   = array.get(ms_hist_sup_lines, i)
                float lvl = not na(ln) ? line.get_y1(ln) : na
                if not na(lvl) and close < lvl
                    line.delete(ln)
                    array.remove(ms_hist_sup_lines, i)
                    if show_sr_price_labels and i < array.size(ms_hist_sup_labels)
                        label.delete(array.get(ms_hist_sup_labels, i))
                        array.remove(ms_hist_sup_labels, i)

// =========================================================================
// AUDIT FIX (P0): CIE CALL HOISTED — BEFORE SIGNAL RENDERING
// ─────────────────────────────────────────────────────────────────────────
// Previously located after barcolor() / signal labels (old Part 5.5).
// That meant gate_fvg(), gate_structure_break(), gate_sweep_reversal()
// all evaluated against the PREVIOUS bar's cie_state. Now runs here —
// after all signal inputs are computed (Part 3) and session transitions
// (Part 4) are applied — so signal labels gate on CURRENT bar context.
//
// NOTE: FVG spawn gates (L2127) and MA background (L1129) still use
// the var-persisted cie_state from the prior bar. This is unavoidable
// without restructuring the entire script, and is acceptable because:
//   - FVG spawn is a structural event (1-bar lag is noise)
//   - MA background is a cosmetic tint (no trading decision)
//
// ⚠️ SINGLETON: analyze_context() holds a module-level var EMA for composite
// smoothing. Call from exactly one location per script — do not duplicate.
//
// ma_partial_align: tri-state int (v1.3 breaking fix).
//   1  = fast > med  (partial bull)
//  -1  = fast < med  (partial bear)
//   0  = flat / na   (indeterminate)
// A bool would collapse the "flat/na" branch into one of the other two,
// making the third state permanently unreachable in f_score_momentum.
// =========================================================================
cie_state := ctx_eng.analyze_context(
    // L1 — Structure
    zz_score_long,
    zz_score_short,
    zz_struct_bias,
    zz_bull_bos,
    zz_bear_bos,
    zz_bull_choch,
    zz_bear_choch,
    zz_high_conv_bull,
    zz_high_conv_bear,
    // L2 — VP
    session_state.poc,
    session_state.vah,
    session_state.val,
    profile_shape,
    va_state,
    skewness_ratio,
    // Phase 3: Prior VA Context
    prior_session_vah,
    prior_session_val,
    prior_session_poc,
    prior_va_close_inside,
    prior_va_poc_tested,
    // L3 — Order Flow
    flow_pressure,
    delta_strength,
    normalized_cvd,
    absorption_signal,
    exhaustion_signal,
    iceberg_detected,
    bearish_div,
    bullish_div,
    smd_distribution,
    smd_accumulation,
    stacked_imb_count,
    // L4 — Liquidity
    zz_bull_sweep,
    zz_bear_sweep,
    failed_auction_bull,
    failed_auction_bear,
    ifvg_flip_bull,
    ifvg_flip_bear,
    // L5 — Momentum
    ma_bull_aligned,
    ma_bear_aligned,
    rotation_factor,
    // ma_partial_align tri-state (v1.3): 1=fast>med, -1=fast<med, 0=flat/na
    not na(ma_fast) and not na(ma_medium)
        ? (ma_fast > ma_medium ? 1 : ma_fast < ma_medium ? -1 : 0)
        : 0,
    // L6 — Session
    session_bar_count,
    timeframe.isintraday,
    timeframe.multiplier,
    math.max(prev_session_bars, session_bar_count + 1),
    // Global
    current_atr,
    close)

bool zz_bull_choch_valid = zz_bull_choch and (na(cie_state) or cie_state.gate_structure_break(true, 1))
bool zz_bear_choch_valid = zz_bear_choch and (na(cie_state) or cie_state.gate_structure_break(true, -1))
bool zz_bull_bos_valid   = zz_bull_bos   and (na(cie_state) or cie_state.gate_structure_break(false, 1))
bool zz_bear_bos_valid   = zz_bear_bos   and (na(cie_state) or cie_state.gate_structure_break(false, -1))

// =========================================================================
// PART 5: RENDERING
// =========================================================================
bool can_render_full = enable_throttling ? opt.can_render_full_detail(25000) : true

// ── PER-BAR PRUNING (v9.7.0) ─────────────────────────────────────────────
// CRITICAL FIX v9.7.0: array.pop() → array.shift() in ALL pruning loops.
// pop() removes from the END (newest) — every new label was deleted on arrival.
// shift() removes from the FRONT (oldest) — correct FIFO pruning behavior.
// The while-size-guard (size > N) prevents shift() from ever being called on
// an empty array, so there is no bounds-error risk with shift() here.
// Caps also reduced: pattern_labels 100→30, ms_hhll 60→20, ms_bos 40→20.
// v9.9.2 PATCH #24: Per-bar pruning replaced with typed helper calls
f_prune_labels(pattern_labels,     30)
f_prune_lines( ms_zz_lines,        50)
f_prune_labels(ms_hhll_labels,     20)
f_prune_labels(ms_bos_labels,      20)
f_prune_lines( ms_hist_res_lines,  hist_sr_max_levels)
f_prune_labels(ms_hist_res_labels, hist_sr_max_levels)
f_prune_lines( ms_hist_sup_lines,  hist_sr_max_levels)
f_prune_labels(ms_hist_sup_labels, hist_sr_max_levels)

if barstate.islast
    // ✅ v9.6.0 FIX 2: Hard caps on secondary box arrays BEFORE any new boxes are
    // drawn this bar. LVN / fast lane / imbalance boxes accumulate across the full
    // session; without caps they push the box count past max_boxes_count before
    // active_va_cloud is (re)allocated, causing Pine to silently evict the cloud.
    // Caps are conservative — these arrays refill from scratch each render pass anyway.
    f_prune_boxes(lvn_boxes,       50)
    f_prune_boxes(fast_lane_boxes, 40)
    f_prune_boxes(imbalance_zones, 40)

    // ✅ v9.5.1 FIX: Prune FVG/IFVG boxes FIRST — before profile render adds new boxes.
    // Ensures FVG split-boxes (2 per gap) are capped before we add ~200 profile boxes,
    // preventing total box count from spiking past max_boxes_count and evicting active_va_cloud.
    fvg_lib.prune(fvg_array, ifvg_array, fvg_max_active)
    render.cleanupBoxes(profile_boxes)
    render.cleanupLines(level_lines)
    render.cleanupPolylines(vp_polylines)
    render.cleanupLabels(session_labels)
    opt.prune_lines(ghost_trail_lines, 150)
    // ✅ v9.6.0: Tile array cap enforced at barstate.islast as a safety net.
    // Primary cap is the FIFO ring buffer in the spawn block (MAX_CLOUD_TILES=100).
    // FIX: Guard with `if not zoneEnd`. On session-transition bars, zoneEnd already
    // wiped the tile array via array.shift() to empty. Running array.shift() again
    // here on an empty array doesn't throw but corrupts internal state going into
    // the next session (double-shift race on the same bar).
    if not zoneEnd
        f_prune_boxes(va_cloud_boxes, 100)
    render.cleanupBoxes(imbalance_zones)
    render.cleanupBoxes(fast_lane_boxes)       // single array (v9.1)
    render.cleanupBoxes(lvn_boxes)
    // v9.5.1: fvg_lib.prune() moved to TOP of barstate.islast block — runs before
    // profile render adds boxes, keeping box budget safe. Removed from here.

    // v9.3: Persistent level lines — delete and redraw every last bar
    // to track the current swing levels forward in real time.
    if show_market_structure and show_swing_levels
        if not na(zz_resistance)
            if not na(ms_res_line)
                line.delete(ms_res_line)
            // SOLID + WIDTH 2 for live — distinguishable from historical dashed lines
            ms_res_line := line.new(
                x1    = bar_index - math.min(bar_index - session_state.start_bar, 200),
                y1    = zz_resistance,
                x2    = bar_index + 50,
                y2    = zz_resistance,
                color = c_swing_res,
                width = 2,
                style = line.style_solid)
            if show_sr_price_labels
                if not na(ms_res_label)
                    label.delete(ms_res_label)
                ms_res_label := label.new(
                    x         = bar_index + 50,
                    y         = zz_resistance,
                    text      = "R: " + str.tostring(zz_resistance, format.mintick),
                    style     = label.style_label_left,
                    color     = color.new(color.red, 35),
                    textcolor = color.white,
                    size      = size.small)

        if not na(zz_support)
            if not na(ms_sup_line)
                line.delete(ms_sup_line)
            ms_sup_line := line.new(
                x1    = bar_index - math.min(bar_index - session_state.start_bar, 200),
                y1    = zz_support,
                x2    = bar_index + 50,
                y2    = zz_support,
                color = c_swing_sup,
                width = 2,
                style = line.style_solid)
            if show_sr_price_labels
                if not na(ms_sup_label)
                    label.delete(ms_sup_label)
                ms_sup_label := label.new(
                    x         = bar_index + 50,
                    y         = zz_support,
                    text      = "S: " + str.tostring(zz_support, format.mintick),
                    style     = label.style_label_left,
                    color     = color.new(color.green, 35),
                    textcolor = color.white,
                    size      = size.small)

        if show_equilibrium and not na(zz_resistance) and not na(zz_support)
            float eq_price = (zz_resistance + zz_support) / 2.0
            if not na(ms_eq_line)
                line.delete(ms_eq_line)
            ms_eq_line := line.new(
                x1    = bar_index - math.min(bar_index - session_state.start_bar, 200),
                y1    = eq_price,
                x2    = bar_index + 50,
                y2    = eq_price,
                color = c_equilibrium,
                width = 1,
                style = line.style_dotted)
            if show_sr_price_labels
                if not na(ms_eq_label)
                    label.delete(ms_eq_label)
                ms_eq_label := label.new(
                    x         = bar_index + 50,
                    y         = eq_price,
                    text      = "EQ: " + str.tostring(eq_price, format.mintick),
                    style     = label.style_label_left,
                    color     = color.new(color.gray, 45),
                    textcolor = color.white,
                    size      = size.tiny)

    // NOTE v9.9.1: session_age is declared here independently — the other
    // session_age at line 1626 lives inside the `if show_va_cloud` block and
    // is out of scope here. Both evaluate identically; this one is required.
    int  max_bars_back      = 4500
    int  session_age        = bar_index - session_state.start_bar
    bool can_safely_render  = session_age < max_bars_back

    if showCur and map.size(session_state.vol_map) > 0 and session_state.max_vol > 0 and can_render_full and can_safely_render

        int   session_length  = bar_index - session_state.start_bar
        if session_length > 0
            int leftMax      = session_state.start_bar
            int rightMax     = bar_index
            int prof_width_c = math.round(session_length * profile_width_pct)
            int prof_width   = opt.optimize_profile_width(prof_width_c, session_length)
            int[] keys       = map.keys(session_state.vol_map)

            if array.size(keys) > 0
                array.sort(keys)
                // AUDIT FIX 2: Conservative effective row cap.
                // Mode 2 emits 2 boxes per row. With heatmap/LVN/FVG/VA cloud enabled,
                // unrestricted max_profile_rows can consume the entire 500-box budget
                // before Pine has a chance to render FVG split-boxes or active_va_cloud.
                int _box_budget_for_profile = 280
                _box_budget_for_profile -= show_lvn_marks   ? 45 : 0
                _box_budget_for_profile -= show_fast_lanes  ? 35 : 0
                _box_budget_for_profile -= show_stacked_imb ? 35 : 0
                _box_budget_for_profile -= show_va_cloud    ? 80 : 0
                _box_budget_for_profile -= show_fvg         ? fvg_max_active * 4 : 0
                _box_budget_for_profile := math.max(60, _box_budget_for_profile)
                int _boxes_per_row       = dispMode == "Mode 2" ? 2 : 1
                int eff_max_profile_rows = math.max(20, math.min(max_profile_rows,
                    math.floor(_box_budget_for_profile / _boxes_per_row)))

                render.RenderConfig config = render.RenderConfig.new(
                    use_heatmap, use_polyline, smooth_polyline, dispMode,
                    profile_width_pct, eff_max_profile_rows,
                    c_cold, c_hot, c_poly, bullCol, bearCol)

                // ── PROFILE BARS / POLYLINE ─────────────────────────────────
                if use_polyline
                    if use_heatmap and use_enhanced_heatmap
                        int _enh_row_skip = math.max(1, math.floor(array.size(keys) / eff_max_profile_rows))
                        for i = 0 to array.size(keys) - 1
                            if i % _enh_row_skip != 0
                                continue
                            int   idx   = array.get(keys, i)
                            float price = binning.f_get_price_from_index(idx, session_state.bin_size)
                            float vol   = map.get(session_state.vol_map, idx)
                            if vol > 0
                                float intensity  = vol / session_state.max_vol * 100
                                int   bar_length = math.round((vol / session_state.max_vol) * prof_width)
                                int   x_coord    = leftMax + bar_length
                                color heat_col   = intensity < 20 ? c_noise
                                                 : intensity < 50 ? c_cold
                                                 : intensity < 80 ? c_warm : c_hot
                                box heatbox = box.new(leftMax, price + session_state.bin_size/10,
                                    x_coord, price - session_state.bin_size + session_state.bin_size/10,
                                    border_color=na, bgcolor=heat_col)
                                array.push(profile_boxes, heatbox)
                    else if use_heatmap and not use_enhanced_heatmap
                        box[] heatmap = render.renderHeatmap(keys, session_state.vol_map,
                            leftMax, prof_width, session_state.bin_size, session_state.max_vol, c_cold, c_hot)
                        for hbox in heatmap
                            array.push(profile_boxes, hbox)

                    polyline poly = render.renderProfilePolyline(keys, session_state.vol_map,
                        session_state.buy_map, config, leftMax, prof_width,
                        session_state.bin_size, session_state.max_vol)
                    if not na(poly)
                        array.push(vp_polylines, poly)
                else
                    box[] rendered_profile = render.renderProfileBars(keys, session_state.vol_map,
                        session_state.buy_map, session_state.sell_map, config,
                        leftMax, prof_width, session_state.bin_size, session_state.max_vol)
                    for pbox in rendered_profile
                        array.push(profile_boxes, pbox)

                // ── LVN MARKERS ─────────────────────────────────────────────
                if show_lvn_marks
                    box[] lvn_renders = render.renderLVNs(keys, session_state.vol_map,
                        leftMax, prof_width, session_state.bin_size, session_state.max_vol,
                        eff_lvn_threshold, c_lvn)
                    for lvn_box in lvn_renders
                        array.push(lvn_boxes, lvn_box)

                // ── v9.1: MERGED FAST LANES — single pass, merged zones ──────
                // Replaces both show_fast_lanes + show_single_prints calls.
                // Fill-check passes current close so zones price is inside are skipped.
                if show_fast_lanes
                    box[] fl_renders = render.renderMergedFastLanes(
                        keys, session_state.vol_map,
                        leftMax, rightMax,
                        session_state.bin_size, session_state.max_vol,
                        eff_fast_lane_threshold, c_fast_lane,
                        fast_lane_min_stack,
                        close)
                    for fl_box in fl_renders
                        array.push(fast_lane_boxes, fl_box)

                // ── STACKED IMBALANCES ──────────────────────────────────────
                if show_stacked_imb
                    box[] imb_renders = render.renderImbalances(keys,
                        session_state.buy_map, session_state.sell_map, session_state.vol_map,
                        leftMax, rightMax, session_state.bin_size, eff_imbalance_ratio, 3)
                    for imb_box in imb_renders
                        array.push(imbalance_zones, imb_box)

                // ── KEY LEVELS & SESSION BOX ────────────────────────────────
                render.LevelConfig level_config = render.LevelConfig.new(
                    showPoc, showVA, showVA, showVAb, showSbox,
                    c_poc, c_vah, c_val, VAbCol, boxBg,
                    pocWid, vahWid, valWid, boxWid)

                if showSbox
                    box sbox = render.renderSessionBox(leftMax, rightMax,
                        session_state.session_high, session_state.session_low, level_config)
                    if not na(sbox)
                        array.push(profile_boxes, sbox)

                line[] rendered_levels = render.renderLevels(session_state.poc,
                    session_state.vah, session_state.val, level_config, leftMax, rightMax)
                for lvl in rendered_levels
                    array.push(level_lines, lvl)

                if showVAb
                    box vabox = render.renderValueAreaBox(leftMax, rightMax,
                        session_state.vah, session_state.val, level_config)
                    if not na(vabox)
                        array.push(profile_boxes, vabox)

                if showLabels
                    // ✅ FIX v9.4.6: label_x = bar_index + 3 so the session summary
                    // always appears at the live bar's right edge. The old formula
                    // (85% of session length) placed the label off-screen to the left
                    // when viewing the live bar on a mature session.
                    int label_x = bar_index + 3
                    current_session_label := render.updateSessionLabel(current_session_label,
                        label_x, session_state.session_high, sessionType,
                        profile_shape, rotation_factor, calc_rotation)

// ── REAL-TIME POC MARKER ────────────────────────────────────────────────────
var label live_poc_marker = na
if enable_realtime_poc and show_live_poc_marker and not na(live_poc)
    if not na(live_poc_marker)
        label.delete(live_poc_marker)
    live_poc_marker := label.new(
        x=bar_index, y=live_poc, text="LIVE POC",
        style=label.style_label_left, color=c_live_poc,
        textcolor=color.white, size=size.tiny, xloc=xloc.bar_index)

// ── PATTERN SIGNAL LABELS ───────────────────────────────────────────────────
// v9.7.0: Tier-based label visibility system.
// Tier 1 (hardcoded ON): SWEEP+FA, CHoCH, FAIL BULL/BEAR, ZZ SWEEP
// Tier 2 (default ON, user-toggle): HH/HL/LH/LL (tiny), BOS (small)
// Tier 3 (default OFF, dashboard-only): ABS, EXHAUST, ICE, DIV, DIST/ACCUM
if barstate.isconfirmed
    // ── TIER 3 — OFF by default ──────────────────────────────────────────────
    // v9.9: raw gate — signal_gate != "CLOSED" is sufficient for Tier 3 signals
    // (no specific L-score thresholds). na() fallback passes when CIE warms up.
    if absorption_signal and show_label_abs and (na(cie_state) or cie_state.signal_gate != "CLOSED")
        label abs_lbl = label.new(bar_index, high, "ABS",
            color=color.yellow, style=label.style_label_down,
            textcolor=color.black, size=size.small, yloc=yloc.abovebar,
            tooltip="Absorption: High volume (2.5× avg), low price movement")
        array.push(pattern_labels, abs_lbl)

    if exhaustion_signal and show_label_exhaust and (na(cie_state) or cie_state.signal_gate != "CLOSED")
        label exhaust_lbl = label.new(bar_index,
            exhaustion_type == "Buy Exhaustion" ? high : low, "🔥 EXHAUST",
            color=exhaustion_type == "Buy Exhaustion" ? color.red : color.lime,
            style=exhaustion_type == "Buy Exhaustion" ? label.style_label_down : label.style_label_up,
            textcolor=color.white, size=size.small,
            yloc=exhaustion_type == "Buy Exhaustion" ? yloc.abovebar : yloc.belowbar,
            // v9.9.1 PATCH #8: Expanded tooltip — was just exhaustion_type string,
            // added signal meaning and action context since label already shows direction.
            tooltip=exhaustion_type + "\nPrice trending " +
                (exhaustion_type == "Buy Exhaustion" ? "up" : "down") +
                " while delta diverges — order flow conviction fading.\n" +
                "Watch for reversal or stall. Wait for CIE CAUTION/OPEN confirmation.")
        array.push(pattern_labels, exhaust_lbl)

    if iceberg_detected and show_label_ice and (na(cie_state) or cie_state.signal_gate != "CLOSED")
        label ice_lbl = label.new(bar_index, high, "🧊 ICE",
            color=color.purple, style=label.style_label_down,
            textcolor=color.white, size=size.small, yloc=yloc.abovebar,
            tooltip="Iceberg Order Detected")
        array.push(pattern_labels, ice_lbl)

    if bearish_div and show_label_div and (na(cie_state) or cie_state.signal_gate != "CLOSED")
        label div_lbl = label.new(bar_index, high, "▼ DIV",
            color=color.red, style=label.style_label_down,
            textcolor=color.white, size=size.small, yloc=yloc.abovebar,
            tooltip="Bearish Divergence: Price higher, Delta lower")
        array.push(pattern_labels, div_lbl)

    if bullish_div and show_label_div and (na(cie_state) or cie_state.signal_gate != "CLOSED")
        label div_lbl = label.new(bar_index, low, "▲ DIV",
            color=color.lime, style=label.style_label_up,
            textcolor=color.black, size=size.small, yloc=yloc.belowbar,
            tooltip="Bullish Divergence: Price lower, Delta higher")
        array.push(pattern_labels, div_lbl)

    // ── TIER 1 — always on ───────────────────────────────────────────────────
    if failed_auction_bear or failed_auction_bull
        // v9.2: skip regular FA label if high-conviction sweep+FA already fires
        // (the SWEEP+FA label below is clearer and supersedes it)
        if not zz_high_conv_bull and not zz_high_conv_bear
            string fa_text  = failed_auction_bear ? "💀 FAIL BEAR" : "💀 FAIL BULL"
            color  fa_color = failed_auction_bear ? color.red : color.lime
            string fa_style = failed_auction_bear ? label.style_label_down : label.style_label_up
            label fa_lbl = label.new(
                x=bar_index, y=failed_auction_bear ? high : low,
                text=fa_text, color=fa_color, style=fa_style,
                textcolor=color.white, size=size.normal,
                yloc=failed_auction_bear ? yloc.abovebar : yloc.belowbar,
                tooltip="Confirmed Failed Auction: price probed beyond value on thin participation, rejected back inside, then displaced away from the failed edge.")
            array.push(pattern_labels, fa_lbl)

    // v9.2 [1]: ZZ Structural Sweep Labels
    // v9.9: gate_sweep_reversal() — L4≥40, L3≥30, gate != CLOSED. Refactored to pass direction.
    if show_zz_sweep
        if (zz_high_conv_bull or zz_bull_sweep) and (na(cie_state) or cie_state.gate_sweep_reversal(1))
            if zz_high_conv_bull
                label hc_lbl = label.new(bar_index, low, "🎯 SWEEP+FA BULL",
                    color=color.new(color.lime, 0), style=label.style_label_up,
                    textcolor=color.black, size=size.normal, yloc=yloc.belowbar,
                    tooltip="High Conviction: ATR ZigZag structural sweep + session failed auction both firing at swing support. Two independent frameworks agree on this reversal.")
                array.push(pattern_labels, hc_lbl)
            else if zz_bull_sweep
                label zs_lbl = label.new(bar_index, low, "🎯 ZZ SWEEP",
                    color=color.new(color.lime, 20), style=label.style_label_up,
                    textcolor=color.black, size=size.small, yloc=yloc.belowbar,
                    tooltip="ZZ Structural Sweep: Liquidity hunt below confirmed ATR swing low — then reclaimed. Stop hunt complete, potential reversal zone.")
                array.push(pattern_labels, zs_lbl)
        if (zz_high_conv_bear or zz_bear_sweep) and (na(cie_state) or cie_state.gate_sweep_reversal(-1))
            if zz_high_conv_bear
                label hc_lbl = label.new(bar_index, high, "🎯 SWEEP+FA BEAR",
                    color=color.new(color.red, 0), style=label.style_label_down,
                    textcolor=color.white, size=size.normal, yloc=yloc.abovebar,
                    tooltip="High Conviction: ATR ZigZag structural sweep + session failed auction both firing at swing resistance. Two independent frameworks agree on this reversal.")
                array.push(pattern_labels, hc_lbl)
            else if zz_bear_sweep
                label zs_lbl = label.new(bar_index, high, "🎯 ZZ SWEEP",
                    color=color.new(color.red, 20), style=label.style_label_down,
                    textcolor=color.white, size=size.small, yloc=yloc.abovebar,
                    tooltip="ZZ Structural Sweep: Liquidity hunt above confirmed ATR swing high — then rejected. Stop hunt complete, potential reversal zone.")
                array.push(pattern_labels, zs_lbl)

    // v9.2 [3]: Smart Money Divergence on Imbalances
    // v9.7.0: gated behind show_label_smd (Tier 3, off by default)
    if show_smd_on_imb and show_label_smd
        if smd_distribution  // v9.9.3 PATCH #31: show_stacked_imb gate removed — SMD signals are independent of stacked imb visual toggle
            label dist_lbl = label.new(bar_index, high, "📤 DIST",
                color=color.new(color.orange, 10), style=label.style_label_down,
                textcolor=color.white, size=size.tiny, yloc=yloc.abovebar,
                tooltip="Distribution: Price rising on declining volume. Bullish stacked imbalances may be sold into — treat these zones with reduced confidence.")
            array.push(pattern_labels, dist_lbl)
        if smd_accumulation  // v9.9.3 PATCH #31: show_stacked_imb gate removed
            label acc_lbl = label.new(bar_index, low, "📥 ACCUM",
                color=color.new(color.teal, 10), style=label.style_label_up,
                textcolor=color.white, size=size.tiny, yloc=yloc.belowbar,
                tooltip="Accumulation: Price falling on declining volume. Bearish stacked imbalances may be quietly absorbed — treat bearish zones with reduced confidence.")
            array.push(pattern_labels, acc_lbl)

// =========================================================================
// v9.3: MARKET STRUCTURE RENDERING — ZZ Lines, HH/HL/LH/LL, BOS/CHoCH
// =========================================================================
// All drawing runs on barstate.isconfirmed so each swing is drawn exactly once.
// zzSwingH / zzSwingL are non-var locals from getZigZagLevels() — they are
// not-na only on the bar the swing is confirmed, na every other bar.
if show_market_structure and barstate.isconfirmed
    bool swing_high_fired = not na(zzSwingH)
    bool swing_low_fired  = not na(zzSwingL)

    // ── ZigZag connecting line ──────────────────────────────────────────────
    // Draws a line from the previous confirmed swing to the current one.
    if show_zz_lines and (swing_high_fired or swing_low_fired)
        float new_swing_price = swing_high_fired ? zzSwingH : zzSwingL
        int   new_swing_bar   = swing_high_fired ? zzHBar   : zzLBar

        if not na(ms_last_swing_price) and not na(ms_last_swing_bar)
            line zz_ln = line.new(
                x1    = ms_last_swing_bar,
                y1    = ms_last_swing_price,
                x2    = new_swing_bar,
                y2    = new_swing_price,
                color = c_zz_line,
                width = 1,
                style = line.style_solid)
            array.push(ms_zz_lines, zz_ln)

        ms_last_swing_price := new_swing_price
        ms_last_swing_bar   := new_swing_bar

    // ── Historical S/R Level Creation ──────────────────────────────────────
    // When a new swing HIGH fires, zz_resistance just updated to the NEW level.
    // The OLD resistance (zz_resistance[1]) becomes a historical line.
    // Guard: must be non-na AND distinct from current value to avoid duplicates.
    if show_hist_sr_levels
        if swing_high_fired and not na(zz_resistance[1]) and zz_resistance[1] != zz_resistance
            // v9.9.2 PATCH #24: inline SR prune → typed helpers (cap-1 preserves pre-insert eviction)
            f_prune_lines( ms_hist_res_lines,  hist_sr_max_levels - 1)
            if show_sr_price_labels
                f_prune_labels(ms_hist_res_labels, hist_sr_max_levels - 1)
            
            float hist_r_price = zz_resistance[1]
            int   hist_r_x1    = bar_index - math.min(bar_index - session_state.start_bar, 500)
            line hist_r = line.new(
                x1    = hist_r_x1,
                y1    = hist_r_price,
                x2    = bar_index + 50,
                y2    = hist_r_price,
                color = c_hist_res,
                width = 1,
                style = line.style_dashed)
            array.unshift(ms_hist_res_lines, hist_r)
            if show_sr_price_labels
                label hist_r_lbl = label.new(
                    x         = bar_index + 50,
                    y         = hist_r_price,
                    text      = str.tostring(hist_r_price, format.mintick),
                    style     = label.style_label_left,
                    color     = color.new(color.red, 65),
                    textcolor = color.white,
                    size      = size.tiny)
                array.unshift(ms_hist_res_labels, hist_r_lbl)

        if swing_low_fired and not na(zz_support[1]) and zz_support[1] != zz_support
            // v9.9.2 PATCH #24: inline SR prune → typed helpers
            f_prune_lines( ms_hist_sup_lines,  hist_sr_max_levels - 1)
            if show_sr_price_labels
                f_prune_labels(ms_hist_sup_labels, hist_sr_max_levels - 1)
            
            float hist_s_price = zz_support[1]
            int   hist_s_x1    = bar_index - math.min(bar_index - session_state.start_bar, 500)
            line hist_s = line.new(
                x1    = hist_s_x1,
                y1    = hist_s_price,
                x2    = bar_index + 50,
                y2    = hist_s_price,
                color = c_hist_sup,
                width = 1,
                style = line.style_dashed)
            array.unshift(ms_hist_sup_lines, hist_s)
            if show_sr_price_labels
                label hist_s_lbl = label.new(
                    x         = bar_index + 50,
                    y         = hist_s_price,
                    text      = str.tostring(hist_s_price, format.mintick),
                    style     = label.style_label_left,
                    color     = color.new(color.green, 65),
                    textcolor = color.white,
                    size      = size.tiny)
                array.unshift(ms_hist_sup_labels, hist_s_lbl)

    // ── HH / HL / LH / LL Labels ────────────────────────────────────────────
    // v9.7.0: gated behind show_label_hhll (Tier 2, on by default).
    // Size changed to tiny + style_none (text-only, no filled box) to reduce
    // visual noise. These labels only need to be readable, not prominent.
    // Cap reduced to 20 in pruning block.
    if show_hhll_labels and show_label_hhll
        if not na(zzHH)
            label hh_lbl = label.new(
                x         = zzHBar,
                y         = zzHH,
                text      = "HH",
                style     = label.style_none,
                color     = c_hh,
                textcolor = color.new(c_hh, 20),
                size      = size.tiny,
                tooltip   = "Higher High — " + str.tostring(zzHH, format.mintick) + "\nBullish structure: market making higher extremes.")
            array.push(ms_hhll_labels, hh_lbl)

        if not na(zzLH)
            label lh_lbl = label.new(
                x         = zzHBar,
                y         = zzLH,
                text      = "LH",
                style     = label.style_none,
                color     = c_lh,
                textcolor = color.new(c_lh, 20),
                size      = size.tiny,
                tooltip   = "Lower High — " + str.tostring(zzLH, format.mintick) + "\nBearish structure developing: swing highs are declining.")
            array.push(ms_hhll_labels, lh_lbl)

        if not na(zzHL)
            label hl_lbl = label.new(
                x         = zzLBar,
                y         = zzHL,
                text      = "HL",
                style     = label.style_none,
                color     = c_hl,
                textcolor = color.new(c_hl, 20),
                size      = size.tiny,
                tooltip   = "Higher Low — " + str.tostring(zzHL, format.mintick) + "\nBullish structure holding: each pullback finds support higher.")
            array.push(ms_hhll_labels, hl_lbl)

        if not na(zzLL)
            label ll_lbl = label.new(
                x         = zzLBar,
                y         = zzLL,
                text      = "LL",
                style     = label.style_none,
                color     = c_ll,
                textcolor = color.new(c_ll, 20),
                size      = size.tiny,
                tooltip   = "Lower Low — " + str.tostring(zzLL, format.mintick) + "\nBearish structure: market printing lower extremes.")
            array.push(ms_hhll_labels, ll_lbl)

    // ── BOS / CHoCH Labels ───────────────────────────────────────────────────
    // CHoCH takes priority over BOS on same bar (can't fire simultaneously
    // but guarded defensively). CHoCH is Tier 1 (always on). BOS is Tier 2.
    // v9.9.3 PATCH #28: CHoCH → gate_structure_break(true) = CAUTION-ok.
    //   BOS → gate_structure_break() = OPEN required (trend continuation).
    //   Both still require L1≥55, L5≥40, L3≥35. STRUCTURE_FLIP bypass kept.
    // Refactored to pass direction parameter (1 = bull, -1 = bear).
    if show_bos_choch
        if zz_bull_choch_valid
            label choch_lbl = label.new(
                x         = bar_index,
                y         = close,
                text      = "⚡ CHoCH ▲",
                style     = label.style_label_up,
                color     = c_choch,
                textcolor = color.white,
                size      = size.normal,
                yloc      = yloc.belowbar,
                tooltip   = "Change of Character BULL — Broke above bearish resistance.\nPotential trend reversal from bearish → bullish. Highest-significance structure event.")
            array.push(ms_bos_labels, choch_lbl)

        else if zz_bear_choch_valid
            label choch_lbl = label.new(
                x         = bar_index,
                y         = close,
                text      = "⚡ CHoCH ▼",
                style     = label.style_label_down,
                color     = c_choch,
                textcolor = color.white,
                size      = size.normal,
                yloc      = yloc.abovebar,
                tooltip   = "Change of Character BEAR — Broke below bullish support.\nPotential trend reversal from bullish → bearish. Highest-significance structure event.")
            array.push(ms_bos_labels, choch_lbl)

        // CHoCH — Tier 1, always shows (no toggle)
        else if zz_bull_bos_valid and show_label_bos
            label bos_lbl = label.new(
                x         = bar_index,
                y         = close,
                text      = "BOS ▲",
                style     = label.style_label_up,
                color     = c_bos,
                textcolor = color.black,
                size      = size.small,
                yloc      = yloc.belowbar,
                tooltip   = "Break of Structure BULL — Broke above confirmed resistance in direction of existing bull bias. Trend continuation signal.")
            array.push(ms_bos_labels, bos_lbl)

        else if zz_bear_bos_valid and show_label_bos
            label bos_lbl = label.new(
                x         = bar_index,
                y         = close,
                text      = "BOS ▼",
                style     = label.style_label_down,
                color     = c_bos,
                textcolor = color.black,
                size      = size.small,
                yloc      = yloc.abovebar,
                tooltip   = "Break of Structure BEAR — Broke below confirmed support in direction of existing bear bias. Trend continuation signal.")
            array.push(ms_bos_labels, bos_lbl)

// Trend validation bar colors
barcolor(show_trend_validation and uptrend_confirmed   ? color.new(color.lime, 70) : na, title="Uptrend Confirmed")
barcolor(show_trend_validation and downtrend_confirmed ? color.new(color.red, 70)  : na, title="Downtrend Confirmed")
barcolor(show_trend_validation and weak_uptrend        ? color.new(color.gray, 50) : na, title="Weak Uptrend")
barcolor(show_trend_validation and weak_downtrend      ? color.new(color.gray, 50) : na, title="Weak Downtrend")

// AUDIT: CIE call moved to before Part 5 rendering (see above).
// Signal labels now gate on current-bar context instead of previous-bar.

// =========================================================================
// PART 6: ENHANCED DASHBOARD
// =========================================================================
var table dash = table.new(position.top_right, 4, 60,
    bgcolor=color.new(color.black, 10), frame_color=color.gray, frame_width=2, border_width=1)

f_dash_col(int col, int logical_row) =>
    (logical_row % 2) * 2 + col

f_dash_row(int logical_row) =>
    math.floor(logical_row / 2)

f_dash_cell(int col, int logical_row, string txt, color text_color = color.white, string text_size = size.tiny, color bgcolor = na) =>
    if dashboard_mode != "Visual HUD"
        table.cell(dash, f_dash_col(col, logical_row), f_dash_row(logical_row), txt,
            text_color=text_color, text_size=text_size, bgcolor=bgcolor)

f_hud_cell(int col, int row, string txt, color text_color = color.white, string text_size = size.tiny, color bgcolor = na) =>
    table.cell(dash, col, row, txt, text_color=text_color, text_size=text_size, bgcolor=bgcolor)

f_hud_meter(float value, float min_value, float max_value) =>
    float span = math.max(max_value - min_value, 0.000001)
    float pct = math.max(0.0, math.min(1.0, (value - min_value) / span))
    int filled = math.round(pct * 10.0)
    string out = ""
    for i = 1 to 10
        out += i <= filled ? "█" : "░"
    out

f_hud_center(float value, float max_abs) =>
    float pct = math.max(-1.0, math.min(1.0, value / math.max(max_abs, 0.000001)))
    int left_fill = pct < 0 ? math.round(math.abs(pct) * 5.0) : 0
    int right_fill = pct > 0 ? math.round(pct * 5.0) : 0
    string out = ""
    for i = 1 to 5
        out += (6 - i) <= left_fill ? "█" : "░"
    out += "│"
    for i = 1 to 5
        out += i <= right_fill ? "█" : "░"
    out

if barstate.islast
    table.clear(dash, 0, 0, 3, 59)

if barstate.islast and show_enhanced_dashboard
    int row = 0

    if dashboard_mode == "Visual HUD"
        int hud_pulse = bar_index % 4
        string hud_scan = hud_pulse == 0 ? "▰▱▱▱" : hud_pulse == 1 ? "▱▰▱▱" : hud_pulse == 2 ? "▱▱▰▱" : "▱▱▱▰"
        color hud_bias_col = zz_struct_bias == 1 ? color.lime : zz_struct_bias == -1 ? color.red : color.gray
        color hud_bias_bg = zz_struct_bias == 1 ? color.new(color.green, 78) : zz_struct_bias == -1 ? color.new(color.red, 78) : color.new(color.gray, 84)
        color hud_cvd_col = cumulative_delta > 0 ? color.lime : cumulative_delta < 0 ? color.red : color.gray
        color hud_flow_col = flow_pressure > 0 ? color.lime : flow_pressure < 0 ? color.red : color.gray
        color hud_delta_col = delta_strength > 20 ? color.lime : delta_strength < -20 ? color.red : color.gray
        string hud_gate = not na(cie_state) ? cie_state.signal_gate : "WARMING"
        color hud_gate_col = not na(cie_state) ? cie_state.phase_color : color.gray
        float hud_cie_score = not na(cie_state) ? cie_state.score : 0.0
        string hud_cie_bias = not na(cie_state) ? (cie_state.bias == 1 ? "BULL" : cie_state.bias == -1 ? "BEAR" : "NEUT") : "NA"
        string hud_ma_status = ma_bull_aligned ? "BULL 3MA" : ma_bear_aligned ? "BEAR 3MA" : ma_2ma_bull ? "BULL 2MA" : ma_2ma_bear ? "BEAR 2MA" : "MIXED"
        color hud_ma_col = ma_bull_aligned or ma_2ma_bull ? color.lime : ma_bear_aligned or ma_2ma_bear ? color.red : color.gray
        bool hud_any_signal = absorption_signal or exhaustion_signal or iceberg_detected or bearish_div or bullish_div or smd_distribution or smd_accumulation
        string hud_signal_txt = absorption_signal ? "ABS" : exhaustion_signal ? exhaustion_type : iceberg_detected ? "ICE" : bearish_div ? "BEAR DIV" : bullish_div ? "BULL DIV" : smd_distribution ? "DIST" : smd_accumulation ? "ACCUM" : "QUIET"
        color hud_signal_col = absorption_signal ? color.yellow : exhaustion_signal ? color.orange : iceberg_detected ? color.purple : bearish_div or smd_distribution ? color.red : bullish_div or smd_accumulation ? color.lime : color.gray
        string hud_va_txt = va_state + (va_state == "Expanding" ? " +" : va_state == "Contracting" ? " -" : " =")
        color hud_va_col = va_state == "Expanding" ? color.orange : va_state == "Contracting" ? color.fuchsia : color.aqua
        string hud_comp_txt = session_state.compression_applied ? compression_trigger_reason : "READY"
        color hud_mem_col = memory_usage > 80 ? color.red : memory_usage > 60 ? color.orange : color.lime

        f_hud_cell(0, 0, "GOD TIER", text_color=color.yellow, text_size=size.normal, bgcolor=color.new(color.gray, 22))
        f_hud_cell(1, 0, "v9.9.6", text_color=color.lime, text_size=size.small, bgcolor=color.new(color.gray, 22))
        f_hud_cell(2, 0, hud_gate, text_color=hud_gate_col, text_size=size.small, bgcolor=color.new(color.gray, 22))
        f_hud_cell(3, 0, hud_scan, text_color=color.aqua, text_size=size.small, bgcolor=color.new(color.gray, 22))

        f_hud_cell(0, 1, "REGIME", text_color=color.white, text_size=size.tiny, bgcolor=hud_bias_bg)
        f_hud_cell(1, 1, current_market_state, text_color=current_market_state_color, text_size=size.small, bgcolor=hud_bias_bg)
        f_hud_cell(2, 1, "STRUCT", text_color=color.white, text_size=size.tiny, bgcolor=hud_bias_bg)
        f_hud_cell(3, 1, zz_struct_bias == 1 ? "BULL" : zz_struct_bias == -1 ? "BEAR" : "NEUT", text_color=hud_bias_col, text_size=size.small, bgcolor=hud_bias_bg)

        f_hud_cell(0, 2, "CIE", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.purple, 86))
        f_hud_cell(1, 2, str.tostring(hud_cie_score, "#") + " " + f_hud_meter(hud_cie_score, 0.0, 100.0), text_color=hud_gate_col, text_size=size.tiny, bgcolor=color.new(color.purple, 86))
        f_hud_cell(2, 2, "BIAS", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.purple, 86))
        f_hud_cell(3, 2, hud_cie_bias, text_color=hud_gate_col, text_size=size.small, bgcolor=color.new(color.purple, 86))

        f_hud_cell(0, 3, "CVD", text_color=color.white, text_size=size.tiny)
        f_hud_cell(1, 3, f_hud_center(normalized_cvd - 50.0, 50.0), text_color=hud_cvd_col, text_size=size.tiny)
        f_hud_cell(2, 3, str.tostring(math.round(cumulative_delta)), text_color=hud_cvd_col, text_size=size.tiny)
        f_hud_cell(3, 3, str.tostring(math.round(normalized_cvd)) + "%", text_color=hud_cvd_col, text_size=size.tiny)

        f_hud_cell(0, 4, "FLOW", text_color=color.white, text_size=size.tiny)
        f_hud_cell(1, 4, f_hud_center(flow_pressure, math.max(math.abs(flow_pressure), 5.0)), text_color=hud_flow_col, text_size=size.tiny)
        f_hud_cell(2, 4, "DELTA", text_color=color.white, text_size=size.tiny)
        f_hud_cell(3, 4, f_hud_center(delta_strength, 100.0), text_color=hud_delta_col, text_size=size.tiny)

        f_hud_cell(0, 5, "MA", text_color=color.white, text_size=size.tiny, bgcolor=color.new(hud_ma_col, 88))
        f_hud_cell(1, 5, hud_ma_status, text_color=hud_ma_col, text_size=size.tiny, bgcolor=color.new(hud_ma_col, 88))
        f_hud_cell(2, 5, "VWAD", text_color=color.white, text_size=size.tiny, bgcolor=color.new(hud_flow_col, 88))
        f_hud_cell(3, 5, str.tostring(vwad, format.volume), text_color=vwad > 0 ? color.lime : color.red, text_size=size.tiny, bgcolor=color.new(hud_flow_col, 88))

        f_hud_cell(0, 6, "RES", text_color=color.rgb(255, 82, 82), text_size=size.tiny)
        f_hud_cell(1, 6, not na(zz_resistance) ? str.tostring(zz_resistance, format.mintick) : "-", text_color=color.rgb(255, 82, 82), text_size=size.tiny)
        f_hud_cell(2, 6, "SUP", text_color=color.rgb(76, 175, 79), text_size=size.tiny)
        f_hud_cell(3, 6, not na(zz_support) ? str.tostring(zz_support, format.mintick) : "-", text_color=color.rgb(76, 175, 79), text_size=size.tiny)

        f_hud_cell(0, 7, "POC", text_color=color.yellow, text_size=size.tiny, bgcolor=color.new(color.yellow, 90))
        f_hud_cell(1, 7, str.tostring(session_state.poc, format.mintick), text_color=color.white, text_size=size.small, bgcolor=color.new(color.yellow, 90))
        f_hud_cell(2, 7, "VA", text_color=color.aqua, text_size=size.tiny, bgcolor=color.new(hud_va_col, 88))
        f_hud_cell(3, 7, hud_va_txt, text_color=hud_va_col, text_size=size.tiny, bgcolor=color.new(hud_va_col, 88))

        f_hud_cell(0, 8, "VAH", text_color=color.aqua, text_size=size.tiny)
        f_hud_cell(1, 8, str.tostring(session_state.vah, format.mintick), text_color=color.aqua, text_size=size.tiny)
        f_hud_cell(2, 8, "VAL", text_color=color.aqua, text_size=size.tiny)
        f_hud_cell(3, 8, str.tostring(session_state.val, format.mintick), text_color=color.aqua, text_size=size.tiny)

        f_hud_cell(0, 9, "SHAPE", text_color=color.white, text_size=size.tiny)
        f_hud_cell(1, 9, profile_shape, text_color=str.contains(profile_shape, "Bullish") ? color.lime : str.contains(profile_shape, "Bearish") ? color.red : color.orange, text_size=size.tiny)
        f_hud_cell(2, 9, "ROT", text_color=color.white, text_size=size.tiny)
        f_hud_cell(3, 9, str.tostring(rotation_factor, "#.##"), text_color=rotation_factor > 0 ? color.lime : color.red, text_size=size.tiny)

        f_hud_cell(0, 10, "SIGNAL", text_color=color.white, text_size=size.tiny, bgcolor=color.new(hud_signal_col, hud_any_signal ? 74 : 90))
        f_hud_cell(1, 10, hud_signal_txt, text_color=hud_signal_col, text_size=size.small, bgcolor=color.new(hud_signal_col, hud_any_signal ? 74 : 90))
        f_hud_cell(2, 10, "BUB/IMB", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.orange, 90))
        f_hud_cell(3, 10, str.tostring(array.size(active_bubbles)) + "/" + str.tostring(array.size(imbalance_zones)), text_color=color.orange, text_size=size.tiny, bgcolor=color.new(color.orange, 90))

        f_hud_cell(0, 11, "SESSION", text_color=color.white, text_size=size.tiny)
        f_hud_cell(1, 11, sessionType, text_color=color.aqua, text_size=size.tiny)
        f_hud_cell(2, 11, "VOL", text_color=color.white, text_size=size.tiny)
        f_hud_cell(3, 11, str.tostring(session_state.total_volume, format.volume), text_color=color.gray, text_size=size.tiny)

        f_hud_cell(0, 12, "COMP", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.gray, 86))
        f_hud_cell(1, 12, hud_comp_txt, text_color=session_state.compression_applied ? color.orange : color.gray, text_size=size.tiny, bgcolor=color.new(color.gray, 86))
        f_hud_cell(2, 12, "MEM", text_color=color.white, text_size=size.tiny, bgcolor=color.new(hud_mem_col, 88))
        f_hud_cell(3, 12, str.tostring(memory_usage, "#.#") + "%", text_color=hud_mem_col, text_size=size.tiny, bgcolor=color.new(hud_mem_col, 88))

    // HEADER
    f_dash_cell( 0, row, "🔱 GOD TIER v9.9.6",    text_color=color.yellow, text_size=size.normal, bgcolor=color.new(color.gray, 30))
    f_dash_cell( 1, row, "CIE INTEGRATED",         text_color=color.lime,   text_size=size.tiny,   bgcolor=color.new(color.gray, 30))
    row += 1

    // MA STATUS
    if enable_ma_system
        f_dash_cell( 0, row, "MA Status", text_color=color.white, text_size=size.tiny)
        string ma_status = ma_bull_aligned ? "🟢 BULL 3MA"
                         : ma_bear_aligned ? "🔴 BEAR 3MA"
                         : ma_2ma_bull     ? "🟡 BULL 2MA"
                         : ma_2ma_bear     ? "🟠 BEAR 2MA" : "⚪ OFF"
        color ma_sc = ma_bull_aligned ? color.lime : ma_bear_aligned ? color.red : ma_2ma_bull ? color.yellow   : ma_2ma_bear ? color.orange : color.gray
        f_dash_cell( 1, row, ma_status, text_color=ma_sc, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "MA Filter", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row, ma_filter_mode, text_color=color.aqua, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "MA Mode", text_color=color.white, text_size=size.tiny)
        string ma_mode_txt = (ma_auto_lengths and ma_adaptive_vol and ma_adaptive_type) ? "DYN+VOL+TYPE" : (ma_auto_lengths and ma_adaptive_vol) ? "DYN+VOL" : (ma_auto_lengths and ma_adaptive_type) ? "DYN+TYPE" : (ma_adaptive_vol and ma_adaptive_type) ? "VOL+TYPE" : ma_auto_lengths ? "DYNAMIC" : ma_adaptive_vol ? "VOL-ADAPT" : ma_adaptive_type ? "REGIME-TYPE" : "MANUAL"
        f_dash_cell( 1, row, ma_mode_txt, text_color=(ma_auto_lengths or ma_adaptive_vol or ma_adaptive_type) ? color.aqua : color.gray, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "MA Type", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row, eff_ma_type, text_color=ma_adaptive_type ? color.lime : color.gray, text_size=size.tiny)
        row += 1

    // SESSION
    f_dash_cell( 0, row, "Session", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, sessionType, text_color=color.aqua, text_size=size.tiny)
    row += 1

    // MARKET STATE
    if show_market_state
        f_dash_cell( 0, row, "Market State", text_color=color.white, text_size=size.small)
        f_dash_cell( 1, row, current_market_state, text_color=current_market_state_color, text_size=size.normal)
        row += 1
        f_dash_cell( 0, row, "State Changes", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row, str.tostring(market_state_changes), text_color=color.gray, text_size=size.tiny)
        row += 1

    // CVD & FLOW
    f_dash_cell( 0, row, "CVD (Norm)", text_color=color.white, text_size=size.small)
    string cvd_text = str.format("{0} ({1}%)", math.round(cumulative_delta), math.round(normalized_cvd))
    f_dash_cell( 1, row, cvd_text, text_color=cumulative_delta > 0 ? color.lime : color.red, text_size=size.small)
    row += 1

    if show_flow_pressure
        f_dash_cell( 0, row, "Flow Pressure", text_color=color.white, text_size=size.small)
        f_dash_cell( 1, row, str.tostring(flow_pressure, "#.##"),
            text_color=flow_pressure > 0 ? color.lime : color.red, text_size=size.small)
        row += 1

    // v9.2 [2]: Delta Strength row
    if show_delta_strength
        f_dash_cell( 0, row, "Delta Strength", text_color=color.white, text_size=size.small)
        color ds_col = delta_strength > 50  ? color.lime
                     : delta_strength > 0   ? color.new(color.lime, 50)
                     : delta_strength < -50 ? color.red
                     : color.new(color.red, 50)
        string ds_arrow = delta_strength > 20 ? " ▲" : delta_strength < -20 ? " ▼" : " –"
        f_dash_cell( 1, row, str.tostring(math.round(delta_strength)) + ds_arrow,
            text_color=ds_col, text_size=size.small)
        row += 1

    // v9.2 [1]: ZZ Structure rows
    if show_zz_sweep
        f_dash_cell( 0, row, "ZZ Bias", text_color=color.white, text_size=size.tiny)
        string zz_bias_txt = zz_struct_bias == 1 ? "🟢 BULL" : zz_struct_bias == -1 ? "🔴 BEAR" : "⚪ NEUTRAL"
        color  zz_bias_col = zz_struct_bias == 1 ? color.lime  : zz_struct_bias == -1 ? color.red : color.gray
        f_dash_cell( 1, row, zz_bias_txt, text_color=zz_bias_col, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "ZZ Levels", text_color=color.white, text_size=size.tiny)
        string zz_r_txt = not na(zz_resistance) ? str.tostring(zz_resistance, format.mintick) : "—"
        string zz_s_txt = not na(zz_support)    ? str.tostring(zz_support,    format.mintick) : "—"
        f_dash_cell( 1, row, zz_r_txt + " / " + zz_s_txt, text_color=color.gray, text_size=size.tiny)
        row += 1

        bool any_zz_sweep = zz_bull_sweep or zz_bear_sweep or zz_high_conv_bull or zz_high_conv_bear or zz_bull_sweep_pending or zz_bear_sweep_pending
        if any_zz_sweep
            f_dash_cell( 0, row, "ZZ Sweep", text_color=color.white, text_size=size.tiny)
            string sweep_txt = zz_high_conv_bull ? "🎯 SWEEP+FA BULL"
                             : zz_high_conv_bear ? "🎯 SWEEP+FA BEAR"
                             : zz_bull_sweep     ? "🎯 ZZ BULL"
                             : zz_bear_sweep     ? "🎯 ZZ BEAR"
                             : zz_bull_sweep_pending ? "RAID PENDING BULL"
                             : "RAID PENDING BEAR"
            color  sweep_col = (zz_high_conv_bull or zz_bull_sweep or zz_bull_sweep_pending) ? color.lime : color.red
            f_dash_cell( 1, row, sweep_txt, text_color=sweep_col, text_size=size.tiny)
            row += 1

    // v9.3: Market Structure section
    if show_market_structure
        f_dash_cell( 0, row, "── STRUCTURE ──", text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.gray, 80))
        f_dash_cell( 1, row, "v9.3",            text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.gray, 80))
        row += 1

        // Structure bias (persistent across session)
        f_dash_cell( 0, row, "Structure Bias", text_color=color.white, text_size=size.small)
        string bias_txt = zz_struct_bias == 1  ? "🟢 BULLISH" : zz_struct_bias == -1 ? "🔴 BEARISH" : "⚪ NEUTRAL"
        color  bias_col = zz_struct_bias == 1  ? color.lime : zz_struct_bias == -1 ? color.red : color.gray
        f_dash_cell( 1, row, bias_txt, text_color=bias_col, text_size=size.small)
        row += 1

        // Resistance / Support levels
        f_dash_cell( 0, row, "Resistance", text_color=color.rgb(255, 82, 82), text_size=size.tiny)
        f_dash_cell( 1, row, not na(zz_resistance) ? str.tostring(zz_resistance, format.mintick) : "—",
            text_color=color.rgb(255, 82, 82), text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "Support", text_color=color.rgb(76, 175, 79), text_size=size.tiny)
        f_dash_cell( 1, row, not na(zz_support) ? str.tostring(zz_support, format.mintick) : "—",
            text_color=color.rgb(76, 175, 79), text_size=size.tiny)
        row += 1

        // Equilibrium
        if show_equilibrium and not na(zz_resistance) and not na(zz_support)
            float eq_dash = (zz_resistance + zz_support) / 2.0
            bool  above_eq = close > eq_dash
            f_dash_cell( 0, row, "Equilibrium", text_color=color.gray, text_size=size.tiny)
            f_dash_cell( 1, row, str.tostring(eq_dash, format.mintick) + (above_eq ? " ▲" : " ▼"),
                text_color=above_eq ? color.lime : color.red, text_size=size.tiny)
            row += 1

        // BOS / CHoCH status
        if show_bos_choch
            bool any_bos_choch = zz_bull_bos_valid or zz_bear_bos_valid or zz_bull_choch_valid or zz_bear_choch_valid
            if any_bos_choch
                f_dash_cell( 0, row, "Signal", text_color=color.white, text_size=size.tiny)
                string sig_txt = zz_bull_choch_valid ? "⚡ CHoCH BULL"
                               : zz_bear_choch_valid ? "⚡ CHoCH BEAR"
                               : zz_bull_bos_valid   ? "BOS ▲ BULL"
                               : "BOS ▼ BEAR"
                color  sig_col = (zz_bull_choch_valid or zz_bull_bos_valid) ? color.lime : color.red
                if zz_bull_choch_valid or zz_bear_choch_valid
                    sig_col := color.rgb(234, 0, 255)
                f_dash_cell( 1, row, sig_txt, text_color=sig_col, text_size=size.small)
                row += 1

        // Structure quality scores
        if show_ms_score
            f_dash_cell( 0, row, "Long Score", text_color=color.white, text_size=size.tiny)
            color ls_col = zz_score_long > 65 ? color.lime : zz_score_long > 35 ? color.yellow : color.gray
            f_dash_cell( 1, row, str.tostring(math.round(zz_score_long)) + "/100",
                text_color=ls_col, text_size=size.tiny)
            row += 1

            f_dash_cell( 0, row, "Short Score", text_color=color.white, text_size=size.tiny)
            color ss_col = zz_score_short > 65 ? color.red : zz_score_short > 35 ? color.orange : color.gray
            f_dash_cell( 1, row, str.tostring(math.round(zz_score_short)) + "/100",
                text_color=ss_col, text_size=size.tiny)
            row += 1

        // v9.3 SR Patch: Nearest historical level proximity
        if show_hist_sr_levels
            float nearest_res_above = na
            float nearest_sup_below = na

            int n_r = array.size(ms_hist_res_lines)
            if n_r > 0
                for i = 0 to n_r - 1
                    line ln = array.get(ms_hist_res_lines, i)
                    if not na(ln)
                        float lvl = line.get_y1(ln)
                        if lvl > close
                            if na(nearest_res_above) or lvl < nearest_res_above
                                nearest_res_above := lvl

            int n_s = array.size(ms_hist_sup_lines)
            if n_s > 0
                for i = 0 to n_s - 1
                    line ln = array.get(ms_hist_sup_lines, i)
                    if not na(ln)
                        float lvl = line.get_y1(ln)
                        if lvl < close
                            if na(nearest_sup_below) or lvl > nearest_sup_below
                                nearest_sup_below := lvl

            if not na(nearest_res_above) or not na(nearest_sup_below)
                f_dash_cell( 0, row, "Hist Levels", text_color=color.white, text_size=size.tiny)
                string res_dist_txt = not na(nearest_res_above) ?
                     "R +" + str.tostring(math.round((nearest_res_above - close) / syminfo.mintick)) + "t" : "R —"
                string sup_dist_txt = not na(nearest_sup_below) ?
                     "S -" + str.tostring(math.round((close - nearest_sup_below) / syminfo.mintick)) + "t" : "S —"
                // Highlight red when price is within half an ATR of historical resistance
                color prox_col = not na(nearest_res_above) and
                     (nearest_res_above - close) < current_atr * 0.5 ? color.red : color.gray
                f_dash_cell( 1, row, res_dist_txt + " / " + sup_dist_txt,
                    text_color=prox_col, text_size=size.tiny)
                row += 1

    f_dash_cell( 0, row, "VWAD", text_color=color.white, text_size=size.small)
    f_dash_cell( 1, row, str.tostring(vwad, format.volume),
        text_color=vwad > 0 ? color.lime : color.red, text_size=size.small)
    row += 1

    // ── TIER 3 SIGNAL ROWS (always in dashboard regardless of label toggles) ──
    // These fire too frequently on NQ 1m/5m to be chart labels but are useful
    // as dashboard context. Labels toggled off → data still visible here.
    f_dash_cell( 0, row, "── SIGNALS ──", text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.gray, 80))
    f_dash_cell( 1, row, "dashboard",     text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.gray, 80))
    row += 1

    if show_absorption
        f_dash_cell( 0, row, "Absorption", text_color=color.white, text_size=size.tiny)
        string abs_txt = absorption_signal ? "🟡 ACTIVE" : "—"
        f_dash_cell( 1, row, abs_txt, text_color=absorption_signal ? color.yellow : color.gray, text_size=size.tiny)
        row += 1

    if show_exhaustion
        f_dash_cell( 0, row, "Exhaustion", text_color=color.white, text_size=size.tiny)
        string ex_txt = exhaustion_signal ? "🔥 " + exhaustion_type : "—"
        f_dash_cell( 1, row, ex_txt, text_color=exhaustion_signal ? color.orange : color.gray, text_size=size.tiny)
        row += 1

    if show_iceberg
        f_dash_cell( 0, row, "Iceberg", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row, iceberg_detected ? "🧊 DETECTED" : "—",
            text_color=iceberg_detected ? color.purple : color.gray, text_size=size.tiny)
        row += 1

    if show_divergence
        bool any_div = bearish_div or bullish_div
        f_dash_cell( 0, row, "CVD Div", text_color=color.white, text_size=size.tiny)
        string div_txt = bearish_div ? "▼ BEAR DIV" : bullish_div ? "▲ BULL DIV" : "—"
        f_dash_cell( 1, row, div_txt, text_color=bearish_div ? color.red : bullish_div ? color.lime : color.gray, text_size=size.tiny)
        row += 1

    if show_smd_on_imb
        bool any_smd = smd_distribution or smd_accumulation
        f_dash_cell( 0, row, "Smart $", text_color=color.white, text_size=size.tiny)
        string smd_txt = smd_distribution ? "📤 DIST" : smd_accumulation ? "📥 ACCUM" : "—"
        f_dash_cell( 1, row, smd_txt, text_color=smd_distribution ? color.orange : smd_accumulation ? color.teal : color.gray, text_size=size.tiny)
        row += 1

    // SESSION VOLUME
    f_dash_cell( 0, row, "Session Vol", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(session_state.total_volume, format.volume), text_color=color.gray, text_size=size.tiny)
    row += 1

    // KEY LEVELS
    f_dash_cell( 0, row, "POC", text_color=color.yellow, text_size=size.small)
    f_dash_cell( 1, row, str.tostring(session_state.poc, format.mintick), text_color=color.white, text_size=size.normal)
    row += 1

    f_dash_cell( 0, row, "VAH/VAL", text_color=color.aqua, text_size=size.small)
    f_dash_cell( 1, row, str.tostring(session_state.vah, format.mintick) + " / "
        + str.tostring(session_state.val, format.mintick), text_color=color.white, text_size=size.small)
    row += 1

    if enable_realtime_poc and not na(live_poc) and not na(confirmed_poc)
        float poc_drift = math.abs(live_poc - confirmed_poc)
        // v9.8.0: eff_poc_drift (ATR × 0.04) replaces mintick × 5 — instrument-adaptive
        if poc_drift > eff_poc_drift
            f_dash_cell( 0, row, "POC Drift", text_color=color.white, text_size=size.tiny)
            string drift_text = str.tostring(poc_drift / syminfo.mintick, "#") + " ticks"
            color drift_col   = poc_drift > current_atr * 0.15 ? color.red : color.orange
            f_dash_cell( 1, row, drift_text, text_color=drift_col, text_size=size.tiny)
        row += 1

    // VA BREATHING
    if show_va_metrics
        f_dash_cell( 0, row, "VA State", text_color=color.white, text_size=size.small)
        color va_col      = va_state == "Expanding" ? color.orange : va_state == "Contracting" ? color.fuchsia : color.aqua
        string va_display = va_state + (va_state == "Expanding" ? " 📈" : va_state == "Contracting" ? " 📉" : "")
        f_dash_cell( 1, row, va_display, text_color=va_col, text_size=size.small)
        row += 1

        f_dash_cell( 0, row, "E/C Count", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row,
            str.tostring(va_expansion_count) + " / " + str.tostring(va_contraction_count),
            text_color=color.gray, text_size=size.tiny)
        row += 1

        // v9.1: Prior VA reference status
        if show_prior_va
            // Section Header
            f_dash_cell( 0, row, "─ Prior VA ─", text_color=color.gray, text_size=size.tiny)
            f_dash_cell( 1, row, "",            text_color=color.gray, text_size=size.tiny)
            row += 1
            
            // Row 1: Range (VAH/VAL)
            string prior_va_text = not na(prior_session_vah) ? str.tostring(prior_session_vah, format.mintick) + " / " + str.tostring(prior_session_val, format.mintick) : "—"
            bool price_inside_prior = not na(prior_session_vah) and not na(prior_session_val) and
                                      close >= prior_session_val and close <= prior_session_vah
            color prior_va_color = not na(prior_session_vah) ? (price_inside_prior ? color.lime : color.orange) : color.white
            f_dash_cell( 0, row, "Range",  text_color=color.white, text_size=size.tiny)
            f_dash_cell( 1, row, prior_va_text, text_color=prior_va_color, text_size=size.tiny)
            row += 1
            
            // Row 2: Prior POC (NPOC tag)
            string poc_val_str = not na(prior_session_poc) ? str.tostring(prior_session_poc, format.mintick) : "—"
            string poc_status  = not na(prior_session_poc) ? (prior_va_poc_tested ? " [TESTED]" : " [NPOC]") : ""
            color  poc_color   = not na(prior_session_poc) ? (prior_va_poc_tested ? color.lime : color.white) : color.gray
            f_dash_cell( 0, row, "POC",  text_color=color.white, text_size=size.tiny)
            f_dash_cell( 1, row, poc_val_str + poc_status, text_color=poc_color, text_size=size.tiny)
            row += 1
            
            // Row 3: PA Status
            string pa_status = "—"
            color  pa_color  = color.gray
            if not na(prior_session_vah)
                if prior_va_close_inside >= 3
                    pa_status := "Accepted"
                    pa_color  := color.lime
                else if (prior_va_touch_vah >= 2 and prior_va_close_above == 0) or (prior_va_touch_val >= 2 and prior_va_close_below == 0)
                    pa_status := "Rejected"
                    pa_color  := color.red
                else if prior_va_touch_vah >= 1 or prior_va_touch_val >= 1
                    pa_status := "Testing"
                    pa_color  := color.orange
            
            f_dash_cell( 0, row, "PA Status", text_color=color.white, text_size=size.tiny)
            f_dash_cell( 1, row, pa_status,    text_color=pa_color,     text_size=size.tiny)
            row += 1

    // PROFILE SHAPE & ROTATION
    f_dash_cell( 0, row, "Shape", text_color=color.white, text_size=size.small)
    color shape_col = str.contains(profile_shape, "Bullish") ? color.lime : str.contains(profile_shape, "Bearish") ? color.red : str.contains(profile_shape, "Bimodal") ? color.orange : color.gray
    f_dash_cell( 1, row, profile_shape, text_color=shape_col, text_size=size.small)
    row += 1

    f_dash_cell( 0, row, "Rotation", text_color=color.white, text_size=size.small)
    f_dash_cell( 1, row, str.tostring(rotation_factor, "#.##"),
        text_color=rotation_factor > 0 ? color.lime : color.red, text_size=size.small)
    row += 1

    // TREND VALIDATION
    if show_trend_validation
        f_dash_cell( 0, row, "Trend Valid", text_color=color.white, text_size=size.small)
        string trend_text = trend_confirmed ? "✓ CONFIRMED" : trend_weak ? "⚠ WEAK" : "NEUTRAL"
        color  trend_col  = trend_confirmed ? color.lime : trend_weak ? color.orange : color.gray
        f_dash_cell( 1, row, trend_text, text_color=trend_col, text_size=size.small)
        row += 1

    // DRAWING OBJECT COUNTS
    f_dash_cell( 0, row, "Ghost Trails", text_color=color.white, text_size=size.tiny)
    string ghost_text = str.tostring(array.size(ghost_trail_lines)) + (use_colored_ghost and show_ghost_trails ? " 🎨" : "")
    f_dash_cell( 1, row, ghost_text,
        text_color=use_colored_ghost ? color.lime : color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "Fast Lanes", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(array.size(fast_lane_boxes)) + " zones",
        text_color=color.rgb(138, 43, 226), text_size=size.tiny)
    row += 1

    // BUBBLE ANALYTICS
    if show_bubble_analytics and array.size(active_bubbles) > 0
        [total_bubb, bull_count, bear_count, net_delta] = bubbles.calculate_bubble_stats(active_bubbles)
        f_dash_cell( 0, row, "Bubbles (B/B)", text_color=color.white, text_size=size.small)
        string ratio_text = str.tostring(bull_count) + " / " + str.tostring(bear_count)
        color  ratio_col  = bull_count > bear_count ? color.lime : bear_count > bull_count ? color.red : color.gray
        f_dash_cell( 1, row, ratio_text, text_color=ratio_col, text_size=size.small)
        row += 1

        if not na(session_state.poc) and enable_smart_pruning
            // v9.8.0: eff_bubble_prox (ATR × 0.12) replaces mintick × ticks
            float prox_tol = eff_bubble_prox
            [poc_bull, poc_bear] = bubbles.count_bubbles_at_price(active_bubbles,
                session_state.poc, prox_tol, 100)
            f_dash_cell( 0, row, "Near POC", text_color=color.white, text_size=size.tiny)
            f_dash_cell( 1, row, str.tostring(poc_bull) + "/" + str.tostring(poc_bear),
                text_color=poc_bull > poc_bear ? color.lime : color.red, text_size=size.tiny)
            row += 1
    else
        f_dash_cell( 0, row, "Bubbles", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row, str.tostring(array.size(active_bubbles)), text_color=color.aqua, text_size=size.tiny)
        row += 1

    f_dash_cell( 0, row, "Imbalances", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(array.size(imbalance_zones)), text_color=color.orange, text_size=size.tiny)
    row += 1

    // BINNING & COMPRESSION
    f_dash_cell( 0, row, "Bin Size", text_color=color.white, text_size=size.small)
    f_dash_cell( 1, row, str.tostring(session_state.bin_size, format.mintick), text_color=color.orange, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "Map Size", text_color=color.white, text_size=size.small)
    f_dash_cell( 1, row, str.tostring(map.size(session_state.vol_map)), text_color=color.aqua, text_size=size.tiny)
    row += 1

    if show_compression_status
        f_dash_cell( 0, row, "Compress Mode", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row, compression_mode, text_color=color.aqua, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "Compress Status", text_color=color.white, text_size=size.tiny)
        string comp_status = session_state.compression_applied ? compression_trigger_reason : "Ready"
        f_dash_cell( 1, row, comp_status,
            text_color=session_state.compression_applied ? color.orange : color.gray, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "Threshold", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row,
            enable_threshold_compression ?
                str.tostring(math.round(eff_compression_trigger / 1000)) + "K" +
                (compression_trigger_auto ? " (auto)" : "") : "N/A",
            text_color=color.aqua, text_size=size.tiny)
        row += 1

    // PERFORMANCE
    if show_performance_metrics and enable_performance_monitoring
        f_dash_cell( 0, row, "Memory Usage", text_color=color.white, text_size=size.tiny)
        color mem_col = memory_usage > 80 ? color.red : memory_usage > 60 ? color.orange : color.lime
        f_dash_cell( 1, row, str.tostring(memory_usage, "#.#") + "%", text_color=mem_col, text_size=size.tiny)
        row += 1

        if emergency_cleanup_triggered
            f_dash_cell( 0, row, "⚠️ Cleanup",  text_color=color.red, text_size=size.tiny)
            f_dash_cell( 1, row, "ACTIVE",       text_color=color.red, text_size=size.tiny)
            row += 1

        f_dash_cell( 0, row, "Smart Pruning", text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row, enable_smart_pruning ? "ON" : "OFF",
            text_color=enable_smart_pruning ? color.lime : color.gray, text_size=size.tiny)
        row += 1

    // SESSION BARS
    f_dash_cell( 0, row, "Session Bars", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(session_bar_count), text_color=color.gray, text_size=size.tiny)
    row += 1

    // DYNAMIC SCALING DEBUG ROWS
    f_dash_cell( 0, row, "MA Lengths",  text_color=color.white, text_size=size.tiny)
    string ma_len_txt = str.tostring(eff_fast_len) + "/" + str.tostring(eff_medium_len) + "/" + str.tostring(eff_slow_len) + (ma_auto_lengths ? " TF×" + str.tostring(_tf_f_ma, "#.##") : "") + (ma_adaptive_vol ? " V×" + str.tostring(ma_vol_factor, "#.##") : "")
    f_dash_cell( 1, row, ma_len_txt, text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "MA Vol Range", text_color=color.white, text_size=size.tiny)
    string ma_range_txt = ma_adaptive_vol ? str.tostring(ma_fast_short_len) + "-" + str.tostring(ma_fast_long_len) + "/" + str.tostring(ma_med_short_len) + "-" + str.tostring(ma_med_long_len) + "/" + str.tostring(ma_slow_short_len) + "-" + str.tostring(ma_slow_long_len) : "OFF"
    f_dash_cell( 1, row, ma_range_txt, text_color=ma_adaptive_vol ? color.aqua : color.gray, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "ZZ Min Bars", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_zz_min_swing), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "Δ Str Len",   text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_delta_len), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "Bubble Age",  text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_bubble_age), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "Imb Ratio",   text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_imbalance_ratio, "#.##"), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "Granularity", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_granularity), text_color=color.yellow, text_size=size.tiny)
    row += 1

    // v9.8.0 DEBUG ROWS — new auto-scaled parameters
    f_dash_cell( 0, row, "── v9.8 SCALE ──", text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.gray, 80))
    f_dash_cell( 1, row, "auto",              text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.gray, 80))
    row += 1

    f_dash_cell( 0, row, "FA Lookback", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_fa_lookback) + (fa_lookback_auto ? " (auto)" : ""), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "SMD Lookback", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_smd_lookback) + (smd_lookback_auto ? " (auto)" : ""), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "FVG Extend", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_fvg_extend) + (fvg_extend_auto ? " (auto)" : ""), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "Mom Lens", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_fast_mom_len) + "/" + str.tostring(eff_medium_mom_len), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "Bub Prox", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_bubble_prox, format.mintick), text_color=color.yellow, text_size=size.tiny)
    row += 1

    f_dash_cell( 0, row, "POC Drift Thr", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, str.tostring(eff_poc_drift, format.mintick), text_color=color.yellow, text_size=size.tiny)
    row += 1

    // ── v9.9: CONTEXT INTELLIGENCE ENGINE SECTION ────────────────────────
    // Gated behind show_market_state — display only when intelligence overlay
    // is on. The CIE computation itself runs unconditionally above (Part 5.5).
    if show_market_state and not na(cie_state)
        f_dash_cell( 0, row, "── CIE v1.4 ──",
            text_color=color.new(color.purple, 20), text_size=size.tiny,
            bgcolor=color.new(color.purple, 85))
        f_dash_cell( 1, row, cie_state.signal_gate,
            text_color=cie_state.phase_color, text_size=size.tiny,
            bgcolor=color.new(color.purple, 85))
        row += 1

        f_dash_cell( 0, row, "Phase",      text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row, cie_state.phase,
            text_color=cie_state.phase_color, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "Score",      text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row,
            str.tostring(cie_state.score, "#.0") + (cie_state.high_conviction ? " ✅" : ""),
            text_color=cie_state.score >= 70 ? color.lime :
                       cie_state.score >= 45 ? color.yellow : color.red,
            text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "Bias",       text_color=color.white, text_size=size.tiny)
        f_dash_cell( 1, row,
            cie_state.bias ==  1 ? "▲ BULL" :
            cie_state.bias == -1 ? "▼ BEAR" : "◆ NEUT",
            text_color=cie_state.bias ==  1 ? color.lime :
                       cie_state.bias == -1 ? color.red  : color.gray,
            text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "L1 Struct",  text_color=color.white,  text_size=size.tiny)
        f_dash_cell( 1, row, str.tostring(cie_state.l1_structure, "#"),
            text_color=color.yellow, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "L2 VP",      text_color=color.white,  text_size=size.tiny)
        f_dash_cell( 1, row, str.tostring(cie_state.l2_vp, "#"),
            text_color=color.yellow, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "L3 OF",      text_color=color.white,  text_size=size.tiny)
        f_dash_cell( 1, row, str.tostring(cie_state.l3_orderflow, "#"),
            text_color=color.yellow, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "L4 Liq",     text_color=color.white,  text_size=size.tiny)
        f_dash_cell( 1, row, str.tostring(cie_state.l4_liquidity, "#"),
            text_color=color.yellow, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "L5 Mom",     text_color=color.white,  text_size=size.tiny)
        f_dash_cell( 1, row, str.tostring(cie_state.l5_momentum, "#"),
            text_color=color.yellow, text_size=size.tiny)
        row += 1

        f_dash_cell( 0, row, "Driver",     text_color=color.white,  text_size=size.tiny)
        f_dash_cell( 1, row, cie_state.top_driver,
            text_color=color.aqua, text_size=size.tiny)
        row += 1

        if cie_state.conflict_detected
            f_dash_cell( 0, row, "⚠️ CONFLICT", text_color=color.orange, text_size=size.tiny)
            f_dash_cell( 1, row, "Layers split", text_color=color.orange, text_size=size.tiny)
            row += 1

    // VERSION BADGE
    f_dash_cell( 0, row, "Version", text_color=color.white, text_size=size.tiny)
    f_dash_cell( 1, row, "✅ v9.9.6", text_color=color.lime, text_size=size.tiny)

// =========================================================================
// PART 6.5: STRATEGY HARNESS
// =========================================================================
var float strat_active_stop = na
var float strat_active_target = na
var int   strat_entry_bar = na
var string strat_active_signal = ""

f_get_strategy_setup() =>
    bool _loose  = strategy_strictness == "Loose"
    bool _strict = strategy_strictness == "Strict"
    bool _rev_on = strategy_mode == "All Signals" or strategy_mode == "Reversal Only"
    bool _rot_on = strategy_mode == "All Signals" or strategy_mode == "Rotation Only"
    bool _str_on = strategy_mode == "All Signals" or strategy_mode == "Structure Only"
    bool _cie_open = na(cie_state) or cie_state.signal_gate != "CLOSED"
    bool _flow_long = _loose or not show_delta ? true : _strict ? flow_pressure > 0 and delta_strength > 0 : flow_pressure > 0 or delta_strength > 0
    bool _flow_short = _loose or not show_delta ? true : _strict ? flow_pressure < 0 and delta_strength < 0 : flow_pressure < 0 or delta_strength < 0
    bool _strict_long_ok = not _strict or na(cie_state) or (cie_state.bias >= 0 and (cie_state.high_conviction or cie_state.score >= 70))
    bool _strict_short_ok = not _strict or na(cie_state) or (cie_state.bias <= 0 and (cie_state.high_conviction or cie_state.score >= 70))
    bool _sweep_gate_long = _loose ? _cie_open : (na(cie_state) or cie_state.gate_sweep_reversal(1))
    bool _sweep_gate_short = _loose ? _cie_open : (na(cie_state) or cie_state.gate_sweep_reversal(-1))
    bool _vp_gate_long = _loose ? _cie_open : (na(cie_state) or cie_state.gate_vp_level(1))
    bool _vp_gate_short = _loose ? _cie_open : (na(cie_state) or cie_state.gate_vp_level(-1))
    bool _struct_gate_long = _loose ? _cie_open : (na(cie_state) or cie_state.gate_structure_break(false, 1))
    bool _struct_gate_short = _loose ? _cie_open : (na(cie_state) or cie_state.gate_structure_break(false, -1))
    bool _has_profile = not na(session_state.poc) and not na(session_state.vah) and not na(session_state.val)
    bool _inside_value = _has_profile and close >= session_state.val and close <= session_state.vah
    bool _poc_cross_up = ta.crossover(close, session_state.poc)
    bool _poc_cross_dn = ta.crossunder(close, session_state.poc)
    bool _sig1_long = _rev_on and zz_high_conv_bull and _sweep_gate_long and _flow_long and _strict_long_ok
    bool _sig1_short = _rev_on and zz_high_conv_bear and _sweep_gate_short and _flow_short and _strict_short_ok
    bool _sig2_long = _rev_on and failed_auction_bull and not zz_high_conv_bull and _sweep_gate_long and _flow_long and _strict_long_ok
    bool _sig2_short = _rev_on and failed_auction_bear and not zz_high_conv_bear and _sweep_gate_short and _flow_short and _strict_short_ok
    bool _sig3_long = _rot_on and _inside_value and _poc_cross_up and _vp_gate_long and _flow_long and _strict_long_ok
    bool _sig3_short = _rot_on and _inside_value and _poc_cross_dn and _vp_gate_short and _flow_short and _strict_short_ok
    bool _sig4_long = _str_on and zz_bull_choch_valid and _flow_long and _strict_long_ok
    bool _sig4_short = _str_on and zz_bear_choch_valid and _flow_short and _strict_short_ok
    bool _trend_cont_long = trend_confirmed and uptrend_confirmed and close > nz(session_state.poc, close) and _vp_gate_long
    bool _trend_cont_short = trend_confirmed and downtrend_confirmed and close < nz(session_state.poc, close) and _vp_gate_short
    bool _sig5_long = _str_on and ((zz_bull_bos_valid and _struct_gate_long) or _trend_cont_long) and _flow_long and _strict_long_ok
    bool _sig5_short = _str_on and ((zz_bear_bos_valid and _struct_gate_short) or _trend_cont_short) and _flow_short and _strict_short_ok
    float _atr = nz(current_atr, high - low)
    float _buffer = _atr * strategy_level_buffer_atr
    float _fallback_risk = _atr * strategy_atr_stop_mult
    bool _long_entry = false
    bool _short_entry = false
    string _entry_signal = ""
    float _stop = na
    float _target = na
    if enable_strategy and allow_strategy_longs and strategy.position_size <= 0
        if _sig1_long
            _long_entry := true
            _entry_signal := "S1 Sweep+FA Long"
            _stop := low - _buffer
            _target := _has_profile and session_state.poc > close ? session_state.poc : close + math.max(close - _stop, _fallback_risk) * strategy_rr
        else if _sig2_long
            _long_entry := true
            _entry_signal := "S2 Failed Auction Long"
            _stop := low - _buffer
            _target := _has_profile and session_state.poc > close ? session_state.poc : close + math.max(close - _stop, _fallback_risk) * strategy_rr
        else if _sig4_long
            _long_entry := true
            _entry_signal := "S4 CHoCH Long"
            _stop := not na(zz_support) ? zz_support - _buffer : close - _fallback_risk
            _target := close + math.max(close - _stop, _fallback_risk) * strategy_rr
        else if _sig5_long
            _long_entry := true
            _entry_signal := "S5 Continuation Long"
            _stop := not na(zz_support) ? zz_support - _buffer : close - _fallback_risk
            _target := _has_profile and session_state.vah > close ? session_state.vah : close + math.max(close - _stop, _fallback_risk) * strategy_rr
        else if _sig3_long
            _long_entry := true
            _entry_signal := "S3 POC Rotation Long"
            _stop := _has_profile ? session_state.poc - _buffer : close - _fallback_risk
            _target := _has_profile and session_state.vah > close ? session_state.vah : close + math.max(close - _stop, _fallback_risk) * strategy_rr
    if enable_strategy and allow_strategy_shorts and strategy.position_size >= 0
        if _sig1_short
            _short_entry := true
            _entry_signal := "S1 Sweep+FA Short"
            _stop := high + _buffer
            _target := _has_profile and session_state.poc < close ? session_state.poc : close - math.max(_stop - close, _fallback_risk) * strategy_rr
        else if _sig2_short
            _short_entry := true
            _entry_signal := "S2 Failed Auction Short"
            _stop := high + _buffer
            _target := _has_profile and session_state.poc < close ? session_state.poc : close - math.max(_stop - close, _fallback_risk) * strategy_rr
        else if _sig4_short
            _short_entry := true
            _entry_signal := "S4 CHoCH Short"
            _stop := not na(zz_resistance) ? zz_resistance + _buffer : close + _fallback_risk
            _target := close - math.max(_stop - close, _fallback_risk) * strategy_rr
        else if _sig5_short
            _short_entry := true
            _entry_signal := "S5 Continuation Short"
            _stop := not na(zz_resistance) ? zz_resistance + _buffer : close + _fallback_risk
            _target := _has_profile and session_state.val < close ? session_state.val : close - math.max(_stop - close, _fallback_risk) * strategy_rr
        else if _sig3_short
            _short_entry := true
            _entry_signal := "S3 POC Rotation Short"
            _stop := _has_profile ? session_state.poc + _buffer : close + _fallback_risk
            _target := _has_profile and session_state.val < close ? session_state.val : close - math.max(_stop - close, _fallback_risk) * strategy_rr
    [_long_entry, _short_entry, _entry_signal, _stop, _target]

[strat_long_entry, strat_short_entry, strat_entry_signal, strat_stop, strat_target] = f_get_strategy_setup()

if strat_long_entry
    strat_active_stop := strat_stop
    strat_active_target := strat_target
    strat_entry_bar := bar_index
    strat_active_signal := strat_entry_signal
    strategy.close("GT-S", comment="Reverse to Long")
    strategy.entry("GT-L", strategy.long, comment="GT Long", alert_message=strat_entry_signal)

if strat_short_entry
    strat_active_stop := strat_stop
    strat_active_target := strat_target
    strat_entry_bar := bar_index
    strat_active_signal := strat_entry_signal
    strategy.close("GT-L", comment="Reverse to Short")
    strategy.entry("GT-S", strategy.short, comment="GT Short", alert_message=strat_entry_signal)

if strategy.position_size > 0 and not na(strat_active_stop) and not na(strat_active_target)
    strategy.exit("GT-L Exit", "GT-L", stop=strat_active_stop, limit=strat_active_target, comment="GT Long Exit", alert_message=strat_active_signal + " exit")

if strategy.position_size < 0 and not na(strat_active_stop) and not na(strat_active_target)
    strategy.exit("GT-S Exit", "GT-S", stop=strat_active_stop, limit=strat_active_target, comment="GT Short Exit", alert_message=strat_active_signal + " exit")

if enable_strategy and strategy_timeout_bars > 0 and strategy.position_size > 0 and not na(strat_entry_bar) and bar_index - strat_entry_bar >= strategy_timeout_bars
    strategy.close("GT-L", comment="Timeout")

if enable_strategy and strategy_timeout_bars > 0 and strategy.position_size < 0 and not na(strat_entry_bar) and bar_index - strat_entry_bar >= strategy_timeout_bars
    strategy.close("GT-S", comment="Timeout")

if strategy.position_size == 0 and not strat_long_entry and not strat_short_entry
    strat_active_stop := na
    strat_active_target := na
    strat_entry_bar := na
    strat_active_signal := ""

// =========================================================================
// PART 7: ALERT SYSTEM
// =========================================================================

// ORDER FLOW
alertcondition(absorption_signal,  "Absorption",         "Absorption detected at {{ticker}}")
alertcondition(exhaustion_signal and exhaustion_type == "Buy Exhaustion",  "Buy Exhaustion",  "Buy Exhaustion signal at {{ticker}}")
alertcondition(exhaustion_signal and exhaustion_type == "Sell Exhaustion", "Sell Exhaustion", "Sell Exhaustion signal at {{ticker}}")
alertcondition(iceberg_detected,   "Iceberg Order",      "Iceberg order detected at {{ticker}}")

// DIVERGENCE
alertcondition(bearish_div, "Bearish Divergence", "Bearish CVD divergence at {{ticker}}")
alertcondition(bullish_div, "Bullish Divergence", "Bullish CVD divergence at {{ticker}}")

// AUCTION PATTERNS
alertcondition(failed_auction_bear or failed_auction_bull,
    "Failed Auction", "Confirmed failed auction at {{ticker}} — value probe rejected and displaced back inside")

// TREND VALIDATION
// v9.9: gate_vp_level() — L2≥45, L3≥30, no conflict. Refactored to pass direction.
int trend_dir = uptrend_confirmed ? 1 : downtrend_confirmed ? -1 : 0
int weak_trend_dir = weak_uptrend ? 1 : weak_downtrend ? -1 : 0
alertcondition(trend_confirmed and (na(cie_state) or cie_state.gate_vp_level(trend_dir)), "Trend Confirmed", "Trend validated by POC migration at {{ticker}}")
alertcondition(trend_weak      and (na(cie_state) or cie_state.gate_vp_level(weak_trend_dir)), "Weak Trend",      "Weak trend detected - POC divergence at {{ticker}}")

// VALUE AREA BREATHING
// v9.9: gate_vp_level() applied — VA state alerts require VP layer confidence. Default dir=0 (neutral).
alertcondition(va_state == "Expanding"   and (na(cie_state) or cie_state.gate_vp_level(0)), "VA Expanding",   "Value Area expanding at {{ticker}}")
alertcondition(va_state == "Contracting" and (na(cie_state) or cie_state.gate_vp_level(0)), "VA Contracting", "Value Area contracting - coiling for breakout at {{ticker}}")

// COMPRESSION SYSTEM
// v9.9.1 PATCH #1b: Expanded to include "Controller" label — Controller-sourced
// compression is semantically threshold-triggered (bin count exceeded), just
// detected via the library rather than the main script's explicit check.
alertcondition(session_state.compression_applied and (compression_trigger_reason == "Threshold" or compression_trigger_reason == "Controller"),
    "Threshold Compression", "Threshold compression triggered at {{ticker}}")
alertcondition(session_state.compression_applied and compression_trigger_reason == "Time-Based",
    "Time Compression", "Time-based compression triggered at {{ticker}}")
alertcondition(session_state.compression_applied and compression_trigger_reason == "Multi-Stage",
    "Multi-Stage Compression", "Multi-stage compression triggered at {{ticker}}")

// PERFORMANCE
alertcondition(emergency_cleanup_triggered, "Emergency Cleanup", "Emergency memory cleanup triggered at {{ticker}}")
alertcondition(memory_usage > 90,           "High Memory Usage", "Memory usage exceeds 90% at {{ticker}}")

// v9.2 [1]: ZZ STRUCTURAL SWEEP ALERTS
alertcondition(show_zz_sweep and zz_bull_sweep,      "ZZ Bull Sweep",           "ZZ structural sweep BULL at {{ticker}} — stop hunt below confirmed swing low, reclaimed")
alertcondition(show_zz_sweep and zz_bear_sweep,      "ZZ Bear Sweep",           "ZZ structural sweep BEAR at {{ticker}} — stop hunt above confirmed swing high, rejected")
alertcondition(zz_high_conv_bull,                    "SWEEP+FA Bull (Hi-Conv)", "HIGH CONVICTION BULL at {{ticker}} — ZZ sweep + failed auction coincide at swing support")
alertcondition(zz_high_conv_bear,                    "SWEEP+FA Bear (Hi-Conv)", "HIGH CONVICTION BEAR at {{ticker}} — ZZ sweep + failed auction coincide at swing resistance")

// v9.2 [3]: SMART MONEY DIVERGENCE ALERTS
alertcondition(show_smd_on_imb and smd_distribution, "Smart Money Distribution", "Distribution: price rising on declining volume at {{ticker}} — imbalances may be sold into")
alertcondition(show_smd_on_imb and smd_accumulation, "Smart Money Accumulation", "Accumulation: price falling on declining volume at {{ticker}} — imbalances may be quietly loaded")

// v9.3: MARKET STRUCTURE ALERTS
alertcondition(show_market_structure and show_bos_choch and zz_bull_choch_valid,
    "CHoCH Bull (Trend Reversal)", "CHoCH BULL at {{ticker}} — structure shifted from bearish → bullish. Potential trend reversal.")
alertcondition(show_market_structure and show_bos_choch and zz_bear_choch_valid,
    "CHoCH Bear (Trend Reversal)", "CHoCH BEAR at {{ticker}} — structure shifted from bullish → bearish. Potential trend reversal.")
alertcondition(show_market_structure and show_bos_choch and zz_bull_bos_valid,
    "BOS Bull (Continuation)",     "BOS BULL at {{ticker}} — broke above confirmed resistance in direction of bull trend.")
alertcondition(show_market_structure and show_bos_choch and zz_bear_bos_valid,
    "BOS Bear (Continuation)",     "BOS BEAR at {{ticker}} — broke below confirmed support in direction of bear trend.")
alertcondition(show_market_structure and not na(zzHH),
    "HH Confirmed",  "Higher High confirmed at {{ticker}} — bullish structural swing.")
alertcondition(show_market_structure and not na(zzLL),
    "LL Confirmed",  "Lower Low confirmed at {{ticker}} — bearish structural swing.")
alertcondition(show_market_structure and not na(zzHL),
    "HL Confirmed",  "Higher Low confirmed at {{ticker}} — bullish structure holding.")
alertcondition(show_market_structure and not na(zzLH),
    "LH Confirmed",  "Lower High confirmed at {{ticker}} — bearish structure developing.")

// v9.9: CIE CONTEXT INTELLIGENCE ALERTS
alertcondition(not na(cie_state) and cie_state.high_conviction and cie_state.bias == 1,
    "CIE High Conviction Bull",
    "CIE BULL CONVICTION at {{ticker}} — Score high — Phase: ready for long setups")
alertcondition(not na(cie_state) and cie_state.high_conviction and cie_state.bias == -1,
    "CIE High Conviction Bear",
    "CIE BEAR CONVICTION at {{ticker}} — Score high — Phase: ready for short setups")
alertcondition(not na(cie_state) and cie_state.signal_gate == "CLOSED",
    "CIE Signal Gate CLOSED",
    "CIE gate CLOSED at {{ticker}} — context invalid, avoid new entries")
alertcondition(not na(cie_state) and cie_state.conflict_detected,
    "CIE Layer Conflict",
    "CIE layers conflicted at {{ticker}} — directional bias split, wait for resolution")

// =========================================================================
// END OF GOD TIER VP v9.9.6
// =========================================================================
// =========================================================================
// PIVOT G-TIER PLOTTING
// =========================================================================
bool use_gtier_shelves = shelf_source == "G-Tier Pivot"
bool use_zz_shelves    = shelf_source == "ATR ZigZag"

plot(show_pvt_hist and use_gtier_shelves and (pvt_max_len == 0 or pvtCountHi < pvt_max_len) ? pvtSeriesHi : na,
     "Historical Resistance (G-Tier)", color=pvtColorHi, linewidth=pvt_line_width,
     style=plot.style_linebr, offset=-(pvt_right + 1))
plot(show_pvt_hist and use_gtier_shelves and (pvt_max_len == 0 or pvtCountLo < pvt_max_len) ? pvtSeriesLo : na,
     "Historical Support (G-Tier)", color=pvtColorLo, linewidth=pvt_line_width,
     style=plot.style_linebr, offset=-(pvt_right + 1))
plot(show_pvt_hist and use_zz_shelves and (pvt_max_len == 0 or zzShelfCountHi < pvt_max_len) ? zzShelfHi : na,
     "Historical Resistance (ATR ZigZag)", color=zzShelfColorHi, linewidth=pvt_line_width,
     style=plot.style_linebr)
plot(show_pvt_hist and use_zz_shelves and (pvt_max_len == 0 or zzShelfCountLo < pvt_max_len) ? zzShelfLo : na,
     "Historical Support (ATR ZigZag)", color=zzShelfColorLo, linewidth=pvt_line_width,
     style=plot.style_linebr)

// Fractal Chaos Channel Style (Aligned to current price)
plot(show_chaos_channel ? pvtSeriesHi : na, "Top Chaos Channel",
     color=color.new(c_hist_res, 60), linewidth=1, style=plot.style_stepline)
plot(show_chaos_channel ? pvtSeriesLo : na, "Bottom Chaos Channel",
     color=color.new(c_hist_sup, 60), linewidth=1, style=plot.style_stepline)
